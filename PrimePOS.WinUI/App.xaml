<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="PrimePOS.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:System.Windows.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.UI.Converters"
    xmlns:globalization="using:Windows.Globalization.NumberFormatting"
    xmlns:helpers="using:PrimePOS.WinUI.Helpers"
    xmlns:local="using:PrimePOS.WinUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!--  Other merged dictionaries here  -->
            </ResourceDictionary.MergedDictionaries>
            <!--  Other app resources here  -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <helpers:NumeroConverterHelper x:Key="NumeroConverterHelper" />
            <helpers:DecimalToDoubleConverter x:Key="DecimalToDouble" />
            <helpers:DateFormatConverter x:Key="DateFormatConverter" />
            <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <helpers:IntToDoubleConverter x:Key="IntToDoubleConverter" />
            <helpers:DecimalToStringConverter x:Key="DecimalToStringConverter" />
            <helpers:IntToStringConverter x:Key="IntToStringConverter" />
            <!--  Formatter global  -->
            <globalization:DecimalFormatter
                x:Key="DecimalFormatter"
                FractionDigits="2"
                IsGrouped="True" />

            <!--  PrimePOS — paleta de marca (facturación / POS)  -->
            <Color x:Key="PrimePOSPrimaryColor">#2D89EF</Color>
            <Color x:Key="PrimePOSPrimaryDarkColor">#1B6FC7</Color>
            <Color x:Key="PrimePOSDangerColor">#C42B1C</Color>
            <Color x:Key="PrimePOSSuccessColor">#1E7145</Color>
            <Color x:Key="PrimePOSWarningColor">#CA5010</Color>
            <Color x:Key="PrimePOSOnAccentColor">#FFFFFF</Color>

            <SolidColorBrush x:Key="PrimePOSPrimaryBrush" Color="{StaticResource PrimePOSPrimaryColor}" />
            <SolidColorBrush x:Key="PrimePOSPrimaryDarkBrush" Color="{StaticResource PrimePOSPrimaryDarkColor}" />
            <SolidColorBrush x:Key="PrimePOSDangerBrush" Color="{StaticResource PrimePOSDangerColor}" />
            <SolidColorBrush x:Key="PrimePOSSuccessBrush" Color="{StaticResource PrimePOSSuccessColor}" />
            <SolidColorBrush x:Key="PrimePOSWarningBrush" Color="{StaticResource PrimePOSWarningColor}" />
            <SolidColorBrush x:Key="PrimePOSOnAccentBrush" Color="{StaticResource PrimePOSOnAccentColor}" />

            <x:Double x:Key="PrimePOSPageTitleSize">28</x:Double>
            <x:Double x:Key="PrimePOSSectionTitleSize">18</x:Double>
            <x:Double x:Key="PrimePOSCardCornerRadius">14</x:Double>

        </ResourceDictionary>
    </Application.Resources>
</Application>
