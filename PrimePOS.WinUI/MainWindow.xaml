<?xml version="1.0" encoding="utf-8"?>

<Window
    x:Class="PrimePOS.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:controls="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    mc:Ignorable="d"
    Title="PrimePOS.WinUI">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    
    <Grid >

        <Grid>
            <NavigationView x:Name="navView"
                            SelectionChanged="navView_SelectionChanged">

                <NavigationView.MenuItems>

                    <NavigationViewItem Content="Dashboard"
                                Tag="dashboard"
                                Icon="Home"/>

                    <NavigationViewItem Content="Ventas"
                                Tag="ventas"
                                Icon="Shop"/>
                    <NavigationViewItem Content="Inventario"
                                Tag="inventario"
                                Icon="Folder"/>

                    <NavigationViewItem Content="Reportes"
                                Tag="reportes"
                                Icon="Contact"/>
                    <NavigationViewItem Content="Tu maldita madre"
                                Tag="administrar"
                                Icon="Home"/>

                    <NavigationViewItem Content="Perfil"
                                Tag="perfil"
                                Icon="Contact"/>
                    <NavigationViewItem Content="Cerrar Session"
                                Tag="cerrarSesion"
                                Icon="ClosePane"/>


                </NavigationView.MenuItems>

                <!-- AQUÍ VA EL FRAME -->
                <NavigationView.Content>
                    <Frame x:Name="contentFrame"/>
                </NavigationView.Content>
            </NavigationView>
        </Grid>

    </Grid>

</Window>
