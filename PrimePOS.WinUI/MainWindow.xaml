<?xml version="1.0" encoding="utf-8" ?>

<Window
    x:Class="PrimePOS.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:PrimePOS.WinUI.Helpers"
    xmlns:local="using:PrimePOS.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PrimePOS"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  =====================  -->
        <!--  TITLE BAR  -->
        <!--  =====================  -->
        <TitleBar
            x:Name="titleBar"
            Grid.Row="0"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind contentFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">

            <!--  =====================  -->
            <!--  IZQUIERDA  -->
            <!--  =====================  -->
            <TitleBar.LeftHeader>

                <StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="10">

                    <Image
                        Width="26"
                        Height="26"
                        Source="Assets/PrimePOS.png" />

                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="PrimePOS" />

                    <PersonPicture
                        Width="35"
                        VerticalAlignment="Center"
                        DisplayName="{Binding UsuarioActual.UsuarioNombre}" />

                    <TextBlock VerticalAlignment="Center" Text="{Binding UsuarioActual.UsuarioNombre}" />

                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Opacity="0.6"
                        Text="{Binding UsuarioActual.RolNombre}" />

                </StackPanel>

            </TitleBar.LeftHeader>

            <!--  =====================  -->
            <!--  DERECHA (ESTO ES LO IMPORTANTE)  -->
            <!--  =====================  -->
            <TitleBar.RightHeader>

                <Button
                    x:Name="btnTema"
                    Width="42"
                    Height="40"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="BtnTema_Click">

                    <FontIcon
                        x:Name="iconTema"
                        FontFamily="Segoe MDL2 Assets"
                        Glyph="&#xE708;" />
                </Button>

            </TitleBar.RightHeader>

        </TitleBar>


        <!--  =====================  -->
        <!--  NAVIGATION VIEW  -->
        <!--  =====================  -->
        <NavigationView
            x:Name="navView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsBackEnabled="False"
            IsPaneOpen="False"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            ItemInvoked="navView_ItemInvoked">

            <NavigationView.MenuItems>

                <NavigationViewItem Content="Dashboard" Tag="dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xECA5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Ventas" Tag="ventas">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEC5A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Inventario" Tag="inventario">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7B8;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Reportes" Tag="reportes">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Administrar" Tag="administrar">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Perfil" Tag="perfil">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE77B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Cerrar sesión" Tag="cerrarSesion">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF3B1;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>


            </NavigationView.FooterMenuItems>
            <NavigationView.Content>

                <Grid>

                    <!--  CONTENIDO  -->
                    <Frame x:Name="contentFrame" />


                </Grid>

            </NavigationView.Content>

        </NavigationView>

        <Grid Grid.Row="1">
            <!--  GENERIC OVERLAY  -->
            <Grid
                x:Name="OverlayHost"
                Tapped="OverlayContainer_Tapped"
                Visibility="Collapsed" />


            <!--  INFOBAR OVERLAY  -->
            <Grid
                Width="500"
                Margin="0,15,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top">

                <InfoBar
                    x:Name="GlobalInfoBar"
                    Title="Mensaje"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    IsOpen="False"
                    Message=""
                    Severity="Informational" />
            </Grid>
        </Grid>
    </Grid>

</Window>