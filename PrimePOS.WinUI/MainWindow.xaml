<?xml version="1.0" encoding="utf-8"?>

<Window
    x:Class="PrimePOS.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:helpers="using:PrimePOS.WinUI.Helpers"
    mc:Ignorable="d"
    Title="PrimePOS.WinUI">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== -->
        <!-- TITLE BAR -->
        <!-- ===================== -->
        <TitleBar
            x:Name="titleBar"
            Grid.Row="0"
            BackRequested="TitleBar_BackRequested"
            PaneToggleRequested="TitleBar_PaneToggleRequested"
            IsBackButtonVisible="{x:Bind contentFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True"
            >

            <!-- ===================== -->
            <!-- IZQUIERDA -->
            <!-- ===================== -->
            <TitleBar.LeftHeader>

                <StackPanel Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">

                    <Image Source="Assets/PrimePOS.png"
                   Width="26"
                   Height="26"/>

                    <TextBlock Text="PrimePOS"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

                    <PersonPicture
                DisplayName="{Binding UsuarioActual.UsuarioNombre}"
                Width="35"
                VerticalAlignment="Center"/>

                    <TextBlock Text="{Binding UsuarioActual.UsuarioNombre}"
                       VerticalAlignment="Center"/>

                    <TextBlock Text="{Binding UsuarioActual.RolNombre}"
                       FontSize="12"
                       Opacity="0.6"
                       VerticalAlignment="Center"/>

                </StackPanel>

            </TitleBar.LeftHeader>

            <!-- ===================== -->
            <!-- DERECHA (ESTO ES LO IMPORTANTE) -->
            <!-- ===================== -->
            <TitleBar.RightHeader>

                <Button x:Name="btnTema"
                Width="42"
                Height="40"
                Background="Transparent"
                BorderThickness="0"
                Click="BtnTema_Click">

                    <FontIcon x:Name="iconTema"
                      Glyph="&#xE708;"
                      FontFamily="Segoe MDL2 Assets"/>
                </Button>

            </TitleBar.RightHeader>

        </TitleBar>


        <!-- ===================== -->
        <!-- NAVIGATION VIEW -->
        <!-- ===================== -->
        <NavigationView
            x:Name="navView"
            ItemInvoked="navView_ItemInvoked"
            Grid.Row="1"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            IsBackEnabled="False"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="False">

            <NavigationView.MenuItems>

                <NavigationViewItem Content="Dashboard" Tag="dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xECA5;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Ventas" Tag="ventas">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEC5A;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Inventario" Tag="inventario">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7B8;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Reportes" Tag="reportes">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Administrar" Tag="administrar">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Perfil" Tag="perfil">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE77B;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Cerrar sesión" Tag="cerrarSesion">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF3B1;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

               
            </NavigationView.FooterMenuItems>
            <NavigationView.Content>

                <Grid>

                    <!-- CONTENIDO -->
                    <Frame x:Name="contentFrame"/>                    


                </Grid>

            </NavigationView.Content>

        </NavigationView>
        <Grid Grid.Row="1">
            <!-- GENERIC OVERLAY -->
            <Grid x:Name="OverlayContainer"
      Opacity="0.8"
      Visibility="Collapsed"
      Tapped="OverlayContainer_Tapped">

                <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
          Opacity="0.8"/>

                <ContentControl x:Name="OverlayContent"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Tapped="OverlayContent_Tapped"/>
            </Grid>

            <!-- PDF OVERLAY -->
            <Grid x:Name="PdfOverlay"
      Visibility="Collapsed"
      Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
      Opacity="0.8"
      Tapped="PdfOverlay_Tapped">

                <Border Width="1000"
            Height="750"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="12"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- HEADER -->
                        <Grid Grid.Row="0"
                  Padding="10">

                            <TextBlock Text="Vista previa PDF"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                            <Button Content="X"
                        
                        HorizontalAlignment="Right"
                        Click="CerrarPdf_Click"/>
                        </Grid>

                        <!-- WEBVIEW -->
                        <WebView2 x:Name="PdfWebView"
                               Grid.Row="1"/>

                    </Grid>

                </Border>

            </Grid>

            <!-- INFOBAR OVERLAY -->
            <Grid VerticalAlignment="Top"
      HorizontalAlignment="Center"
      Margin="0,15,0,0"
      Width="500">

                <InfoBar x:Name="GlobalInfoBar"
             IsOpen="False"
             VerticalAlignment="Top"
             HorizontalAlignment="Stretch"
             Severity="Informational"
             Title="Mensaje"
             Message=""/>
            </Grid>
        </Grid>
    </Grid>
    
</Window>