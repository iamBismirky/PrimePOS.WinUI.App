<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.CategoriaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d">




    <Grid Padding="20" RowSpacing="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITULO -->
        <TextBlock
            Text="Gestión de Categorias"
            FontSize="28"
            FontWeight="SemiBold"/>

        <!-- FORMULARIO -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="10">


            <TextBox
                x:Name="txtNombre"
                 Header="Descripcion"
                 Width="250"/>
            <ToggleSwitch x:Name="tgEstado"
                Header="Estado"
                OnContent="Activo"
                OffContent="Inactivo"
                IsOn="True"/>
            <Button
                Content="Crear"
                Style="{StaticResource AccentButtonStyle}"
                Click="BtnCrearCategoria_Click"/>

            <Button
                Content="Actualizar"
                Click="BtnActualizarCategoria_Click"/>

            <Button
                Content="Eliminar"
                Click="BtnEliminarCategoria_Click"/>
            <Button
                 Content="Limpiar"
                 Click="BtnLimpiar_Click"/>
        </StackPanel>

        <!-- DATAGRID -->
        <controls:DataGrid
            Grid.Row="2"
            x:Name="dgCategorias"
            AutoGenerateColumns="False"
            SelectionMode="Single"
            SelectionChanged="dgCategorias_SelectionChanged"
            IsReadOnly="True">

            <controls:DataGrid.Columns>
                

                <controls:DataGridTextColumn
                    Header="Nombre"
                    Binding="{Binding Nombre}"
                    Width="auto"/>

                <controls:DataGridCheckBoxColumn
                    Header="Estado"
                    Binding="{Binding Estado}"
                    Width="auto"/>

            </controls:DataGrid.Columns>

        </controls:DataGrid>

    </Grid>

</Page>

