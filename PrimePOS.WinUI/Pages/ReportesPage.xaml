<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.ReportesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls" xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Filtros -->
            <RowDefinition Height="Auto"/>
            <!-- Indicadores -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Botones acción -->
        </Grid.RowDefinitions>

        <!-- 1️⃣ Filtros de reporte -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="15">
            <TextBlock Text="Tipo de Reporte:" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbTipoReporte" Width="200" SelectedIndex="0">
                <ComboBoxItem Content="Ventas"/>
                <ComboBoxItem Content="Clientes"/>
                <ComboBoxItem Content="Productos"/>
            </ComboBox>

            <TextBlock Text="Desde:" VerticalAlignment="Center"/>
            <DatePicker x:Name="dpFechaInicio"/>

            <TextBlock Text="Hasta:" VerticalAlignment="Center"/>
            <DatePicker x:Name="dpFechaFin"/>

            <Button Content="Generar Reporte" Click="BtnGenerarReporte_Click" Background="#FF2D89EF" Foreground="White"/>
            <Button Content="Limpiar Filtros" Click="BtnLimpiarFiltros_Click"/>
        </StackPanel>

        <!-- 2️⃣ Indicadores resumidos -->
        <Grid Grid.Row="1" ColumnSpacing="20" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FF2D89EF" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Total" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Total" FontSize="20" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#FF1E7145" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Cantidad Registros" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Cantidad"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#FFDA532C" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Promedio" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Promedio"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 3️⃣ DataGrid con resultados -->
        <controls:DataGrid Grid.Row="2" x:Name="dgReportes"
                  AutoGenerateColumns="False"
                  RowHeight="40"
                  ColumnHeaderHeight="40"
                  FontSize="14">
            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="Fecha" Binding="{Binding Fecha}" Width="*"/>
                <controls:DataGridTextColumn Header="Producto/Cliente" Binding="{Binding Nombre}" Width="2*"/>
                <controls:DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="*"/>
                <controls:DataGridTextColumn Header="Precio Unitario" Binding="{Binding PrecioUnitario}" Width="*"/>
                <controls:DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal}" Width="*"/>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <!-- 4️⃣ Botones de acción -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Exportar a Excel" Click="BtnExportarExcel_Click" Background="#FF2D89EF" Foreground="White"/>
            <Button Content="Exportar a PDF" Click="BtnExportarPDF_Click" Background="#FF1E7145" Foreground="White"/>
        </StackPanel>
    </Grid>
</Page>