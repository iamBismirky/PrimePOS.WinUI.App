<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.ProductoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid x:Name="MainRoot">

        <Grid Padding="20" RowSpacing="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <TextBlock Grid.Row="0"
                       Text="Gestión de Productos"
                       FontSize="24"
                       FontWeight="SemiBold"/>

            <!-- SEARCH + BUTTON -->
            <StackPanel Grid.Row="1" Orientation="Horizontal">

                <Border Background="{ThemeResource CardBackgroundFillColorDefault}"
                        CornerRadius="12"
                        Padding="20"
                        Width="400"
                        Margin="20"
                        Height="90">

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">

                        <TextBox Width="300"
                                 PlaceholderText="Buscar..."
                                 Text="{Binding Buscar, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextChanged="Buscar_TextChanged"/>

                        <Button Command="{Binding FiltrarCommand}">
                            <FontIcon Glyph="&#xE721;"
                                      FontFamily="Segoe Fluent Icons"
                                      FontSize="18"/>
                        </Button>

                    </StackPanel>
                </Border>

                <!-- NUEVO -->
                <Button Command="{Binding NuevoCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="20"/>
                        <TextBlock Text="Nuevo"/>
                        <ProgressRing 
                                      Width="20"
                                      Height="20"
                                      IsActive="{Binding IsLoading}"
                                      Visibility="{Binding IsLoading}"/>
                    </StackPanel>
                </Button>

            </StackPanel>

            <!-- GRID -->
            <Grid Grid.Row="2">
                <Border 
                    Padding="15"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                    <StackPanel Spacing="10">

                        <TextBlock Text="Listado Productos"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                        <controls:DataGrid ItemsSource="{Binding Productos}"
                                       AutoGenerateColumns="False"
                                       IsReadOnly="True">

                            <controls:DataGrid.Columns>

                                <controls:DataGridTextColumn Header="Codigo" Binding="{Binding Codigo}"/>
                                <controls:DataGridTextColumn Header="Codigo Barra" Binding="{Binding CodigoBarra}"/>
                                <controls:DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}"/>
                                <controls:DataGridTextColumn Header="Descripcion" Binding="{Binding Descripcion}"/>
                                <controls:DataGridTextColumn Header="Categoria" Binding="{Binding CategoriaNombre}"/>
                                <controls:DataGridTextColumn Header="Precio Compra" Binding="{Binding PrecioCompra, Converter={StaticResource NumeroConverterHelper}}"/>
                                <controls:DataGridTextColumn Header="Precio Venta" Binding="{Binding PrecioVenta, Converter={StaticResource NumeroConverterHelper}}"/>
                                <controls:DataGridCheckBoxColumn Header="Estado" Binding="{Binding Estado}"/>
                                <controls:DataGridTextColumn Header="Fecha Registro" Binding="{Binding FechaRegistro}"/>


                                <!-- ACCIONES -->
                                <controls:DataGridTemplateColumn Header="Acciones">
                                    <controls:DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>

                                            <StackPanel Orientation="Horizontal" Spacing="5">

                                                <!-- EDITAR -->
                                                <Button Click="Editar_Click"
                                                        Tag="{Binding}">
                                                    <SymbolIcon Symbol="Edit"/>
                                                </Button>

                                                <!-- DESACTIVAR -->
                                                <Button Click="Desactivar_Click"
                                                    Tag="{Binding}"
                                                    Background="Red">
                                                    <SymbolIcon Symbol="Delete"/>
                                                </Button>

                                            </StackPanel>

                                        </DataTemplate>
                                    </controls:DataGridTemplateColumn.CellTemplate>
                                </controls:DataGridTemplateColumn>

                            </controls:DataGrid.Columns>

                        </controls:DataGrid>

                    </StackPanel>
                </Border>
                <!-- LOADING -->
                <Grid Visibility="{Binding IsLoading}"
                      Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                      Opacity="0.8">

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="10">

                        <ProgressRing IsActive="True" Width="50" Height="50"/>
                        <TextBlock Text="Cargando..."/>

                    </StackPanel>
                </Grid>
            </Grid>



        </Grid>

        <!-- OVERLAY -->
        <Grid Visibility="{Binding IsOverlayVisible}"
              Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
              Opacity="0.8">

            <Border Width="400"
                    Padding="20"
                    Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                    CornerRadius="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel Spacing="10">

                    <TextBlock Text="Producto"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <Line X1="0" X2="1" Stretch="Fill" Stroke="Gray" StrokeThickness="1"/>

                    <StackPanel Orientation="Horizontal" Spacing="50" HorizontalAlignment="Stretch">
                        <TextBlock>
                            <Run Text="Codigo"/>
                            <Run Text="{Binding Codigo}"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Fecha Registro"/>
                            <Run Text="{Binding FechaRegistro}"/>
                        </TextBlock>
                    </StackPanel>


                    <Line X1="0" X2="1" Stretch="Fill" Stroke="Gray" StrokeThickness="1"/>
                    <TextBox Header="Nombre" 
                             Text="{Binding Nombre, Mode=TwoWay}"/>
                    <TextBox Header="Descripcion" 
                             Text="{Binding Descripcion, Mode=TwoWay}"/>
                    <TextBox Header="Codigo Barras" 
                             Text="{Binding CodigoBarra, Mode=TwoWay}"/>
                    <ComboBox Header="Categoria" 
                              DisplayMemberPath="Nombre"
                              PlaceholderText="Seleccione una categoria"
                              SelectedItem="{Binding CategoriaSeleccionada, Mode=TwoWay}" 
                              ItemsSource="{Binding Categorias}"/>
                    <NumberBox Header="Precio Compra" 
                               Value="{Binding PrecioCompraUI, Mode=TwoWay}"
                               NumberFormatter="{StaticResource DecimalFormatter}"/>
                    <NumberBox Header="Precio Venta" 
                               Value="{Binding PrecioVentaUI, Mode=TwoWay}"
                               NumberFormatter="{StaticResource DecimalFormatter}"/>
                    <NumberBox Header="Existencia" 
                               Value="{Binding ExistenciaUI, Mode=TwoWay}"/>
                    <ToggleSwitch Header="Estado" 
                                  IsOn="{Binding Estado, Mode=TwoWay}"/>

                    <Line X1="0" X2="1" Stretch="Fill" Stroke="Gray" StrokeThickness="1"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="10">
                        
                        <Button Command="{Binding CerrarOverlayCommand}"
                                Background="Red">
                            <TextBlock Text="Cancelar"/>
                        </Button>

                        <Button Command="{Binding GuardarCommand}"
                                Background="#FF2D89EF"
                                Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xF78C;" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock x:Name="txtGuardar" Text="Guardar"/>
                                <ProgressRing Width="20"
                                              Height="20"
                                              IsActive="{Binding IsLoading}"
                                              Visibility="{Binding IsLoading}"/>
                            </StackPanel>
                        </Button>

                       

                    </StackPanel>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>
</Page>