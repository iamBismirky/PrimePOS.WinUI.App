<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.AdministrarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid Padding="50">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="-30,-40,0,0">
            <TextBlock Text="Administrar" FontSize="28" FontWeight="Bold"/>
        </StackPanel>
        <!-- Card Usuario --> 
        <Button Grid.Column="0"
            Margin="10"
            Click="BtnGestionUsuarios_Click">

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="16"
                Padding="20">

                <StackPanel HorizontalAlignment="Center"
                        Spacing="10">

                    <SymbolIcon Symbol="Contact" Width="40" Height="40"/>


                    <TextBlock Text="Gestion de usuarios"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>
        </Button>


        <!-- Card Rol -->
        <Button Grid.Column="1"
            Margin="10"
            Click="BtnGestionRoles_Click">

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="16"
                Padding="20">

                <StackPanel HorizontalAlignment="Center"
                        Spacing="10">

                    <SymbolIcon Symbol="Admin" Width="40" Height="40"
                            />

                    <TextBlock Text="Gestion de Roles"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>
        </Button>


        <!-- Card Producto -->
        <Button Grid.Column="2"
            Margin="10"
            Click="BtnGestionProductos_Click">

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="16"
                Padding="20">

                <StackPanel HorizontalAlignment="Center"
                        Spacing="10">

                    <SymbolIcon Symbol="Shop" Width="40" Height="40"/>

                    <TextBlock Text="Gestion de productos"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>


                </StackPanel>

            </Border>
        </Button>

        <!-- Card Categoria -->
        <Button Grid.Column="0"
                Grid.Row="1"
                Margin="10"
                Click="BtnGestionCategorias_Click">

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="16"
                Padding="20">

                <StackPanel HorizontalAlignment="Center"
                            Spacing="10">

                    <SymbolIcon Symbol="Shop" Width="40" Height="40"/>

                    <TextBlock Text="Gestion de categorias"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>
        </Button>
        <Button Grid.Column="1"
        Grid.Row="1"
        Margin="10"
        Click="BtnGestionClientes_Click">

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16"
                    Padding="20">

                <StackPanel HorizontalAlignment="Center"
                    Spacing="10">

                    <SymbolIcon Symbol="Shop" Width="40" Height="40"/>

                    <TextBlock Text="Gestion de Clientes"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>
        </Button>


    </Grid>
</Page>
