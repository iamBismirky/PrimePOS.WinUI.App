<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.AdministrarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid Padding="50">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="-30,-40,0,0">
            <TextBlock Text="Administrar" FontSize="28" FontWeight="Bold"/>
        </StackPanel>



        <!-- Card Usuario -->
        <Button Grid.Column="0"
        Grid.Row="1"
        Margin="10"
        Width="300"
        Click="BtnGestionUsuarios_Click">

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="5"
            Padding="20"
            Width="300"
            HorizontalAlignment="Center">

                <StackPanel HorizontalAlignment="Center"
                    Spacing="10"
                    Orientation="Vertical"
                    VerticalAlignment="Center"
                    >

                    <FontIcon Glyph="&#xE77B;" 
                      FontFamily="Segoe Fluent Icons"
                      FontSize="40"
                      />

                    <TextBlock Text="Gestion de Usuarios"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>


                </StackPanel>

            </Border>
        </Button>


        <!-- Card Rol -->
        <Button Grid.Column="1"
        Grid.Row="1"
        Margin="10"
        Width="300"
        Click="BtnGestionRoles_Click">

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="5"
            Padding="20"
            Width="300"
            HorizontalAlignment="Center">

                <StackPanel HorizontalAlignment="Center"
                    Spacing="10"
                    Orientation="Vertical"
                    VerticalAlignment="Center"
                    >

                    <FontIcon Glyph="&#xEBDA;" 
                      FontFamily="Segoe Fluent Icons"
                      FontSize="40"
                      />

                    <TextBlock Text="Gestion de Roles"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>


                </StackPanel>

            </Border>
        </Button>


        <!-- Card Producto -->
        <Button Grid.Column="0"
                Grid.Row="2"
                Margin="10"
                Width="300"
                Click="BtnGestionProductos_Click">

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="5"
                    Padding="20"
                    Width="300"
                    HorizontalAlignment="Center">

                <StackPanel HorizontalAlignment="Center"
                            Spacing="10"
                            Orientation="Vertical"
                            VerticalAlignment="Center"
                            >

                    <FontIcon Glyph="&#xEC09;" 
                              FontFamily="Segoe Fluent Icons"
                              FontSize="40"
                              />

                    <TextBlock Text="Gestion de productos"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>


                </StackPanel>

            </Border>
        </Button>
        
        <!-- Card Categoria -->
        <Button Grid.Column="1"
        Grid.Row="2"
        Margin="10"
        Width="300"
        Click="BtnGestionCategorias_Click">

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="5"
            Padding="20"
            Width="300"
            HorizontalAlignment="Center">

                <StackPanel HorizontalAlignment="Center"
                    Spacing="10"
                    Orientation="Vertical"
                    VerticalAlignment="Center"
                    >

                    <FontIcon Glyph="&#xE762;" 
                      FontFamily="Segoe Fluent Icons"
                      FontSize="40"
                      />

                    <TextBlock Text="Gestion de Categorias"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>


                </StackPanel>

            </Border>
        </Button>
        
        <!-- Card Cliente -->
        <Button Grid.Column="0"
        Grid.Row="3"
        Margin="10"
        Width="300"
        Click="BtnGestionClientes_Click">

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="5"
            Padding="20"
            Width="300"
            HorizontalAlignment="Center">

                <StackPanel HorizontalAlignment="Center"
                    Spacing="10"
                    Orientation="Vertical"
                    VerticalAlignment="Center"
                    >

                    <FontIcon Glyph="&#xE716;" 
                      FontFamily="Segoe Fluent Icons"
                      FontSize="40"
                      />

                    <TextBlock Text="Gestion de Clientes"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>


                </StackPanel>

            </Border>
        </Button>
        
        <!-- Card Caja -->
        <Button Grid.Column="1"
        Grid.Row="3"
        Margin="10"
        Width="300"
        Click="BtnGestionCajas_Click">

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="5"
            Padding="20"
            Width="300"
            HorizontalAlignment="Center">

                <StackPanel HorizontalAlignment="Center"
                    Spacing="10"
                    Orientation="Vertical"
                    VerticalAlignment="Center"
                    >

                    <FontIcon Glyph="&#xE7B8;" 
                      FontFamily="Segoe Fluent Icons"
                      FontSize="40"
                      />

                    <TextBlock Text="Gestion de Cajas"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>


                </StackPanel>

            </Border>
        </Button>
       
    </Grid>
</Page>
