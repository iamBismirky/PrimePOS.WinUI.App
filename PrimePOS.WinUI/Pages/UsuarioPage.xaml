<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.UsuarioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:helpers="using:PrimePOS.WinUI.Helpers"
    xmlns:globalization="using:Windows.Globalization.NumberFormatting"
    Loaded="Page_Loaded">

    <Page.Resources>
        <helpers:NumeroConverterHelper x:Key="NumeroConverterHelper"/>
        <globalization:DecimalFormatter x:Key="DecimalFormatter" FractionDigits="2" IsGrouped="true"/>
    </Page.Resources>

    <Grid>
        <Grid Padding="20" RowSpacing="20" x:Name="MainGrid">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Gestión de Usuarios"
                           FontSize="24"
                           FontWeight="SemiBold">
                </TextBlock>
            </StackPanel>

            <!-- CARD FORMULARIO -->
            <StackPanel Orientation="Horizontal"
                        Grid.Row="1">



                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefault}"
                        CornerRadius="12"
                        Padding="20"
                        Width="400"
                        Margin="20"
                        Height="90">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">

                        <TextBox x:Name="txtBuscar"
                                 PlaceholderText="Buscar..."
                                 TextChanged="txtBuscar_TextChanged"
                                 Width="300"
                                 />
                        <Button Click="Buscar_Click">

                            <FontIcon Glyph="&#xE721;" 
                                  FontFamily="Segoe Fluent Icons" 
                                  FontSize="18"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>

                </Border>
                <Border 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="12"
                        Padding="10"
                        Width="115"
                        Height="50"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center">

                    <Button Click="AbrirOverlay_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE710;" 
                                      FontFamily="Segoe Fluent Icons" 
                                      FontSize="20"/>
                            <TextBlock Text="Nuevo"/>
                        </StackPanel>


                    </Button>
                </Border>

            </StackPanel>



            <!-- 📋 GRID -->
            <Grid Grid.Row="2">


                <Border 
                Padding="15"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                    <StackPanel Spacing="10">

                        <!-- HEADER -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                            <TextBlock Text="Listado Usuarios"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>


                        </StackPanel>

                        <!-- DATA GRID -->
                        <controls:DataGrid x:Name="dgUsuarios"
                                           AutoGenerateColumns="False"
                                           IsReadOnly="True"
                                           MaxHeight="400">

                            <controls:DataGrid.Columns>

                                <controls:DataGridTextColumn Header="Codigo" Binding="{Binding Codigo}"/>
                                <controls:DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}"/>
                                <controls:DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}"/>
                                <controls:DataGridTextColumn Header="Nombre Usuario" Binding="{Binding Username}"/>
                                <controls:DataGridCheckBoxColumn Header="Estado" Binding="{Binding Estado}"/>
                                <controls:DataGridTextColumn Header="Fecha de Registro" Binding="{Binding FechaRegistro}"/>
                                <!-- 🔥 ACCIONES -->
                                <controls:DataGridTemplateColumn Header="Acciones">
                                    <controls:DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>

                                            <StackPanel Orientation="Horizontal" Spacing="5">

                                                <Button Click="Editar_Click"
                                                        Background="{ThemeResource AccentAAFillColorDefaultBrush}"
                                                        Tag="{Binding}">
                                                    <SymbolIcon Symbol="View"/>
                                                </Button>

                                                <Button Click="Eliminar_Click"
                                                        Tag="{Binding}"
                                                        Background="Red">
                                                    <SymbolIcon Symbol="Delete"/>
                                                </Button>

                                            </StackPanel>

                                        </DataTemplate>
                                    </controls:DataGridTemplateColumn.CellTemplate>
                                </controls:DataGridTemplateColumn>

                            </controls:DataGrid.Columns>

                        </controls:DataGrid>

                    </StackPanel>

                </Border>
                <!-- OVERLAY LOADING -->
                <Grid x:Name="OverlayLoading"
                      Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                      Visibility="Collapsed"
                      Opacity="0.8">

                    <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10">

                        <ProgressRing IsActive="True"
                          Width="50"
                          Height="50"/>

                        <TextBlock Text="Cargando..." />

                    </StackPanel>

                </Grid>

            </Grid>

        </Grid>

        <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
              Opacity="0.8"
              x:Name="OverlayUsuario"
              Visibility="Collapsed"
              >

            <Border 
           
             Width="400"
             Padding="20"
             Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
             CornerRadius="12"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">

                <StackPanel Spacing="10">

                    <TextBlock Text="Rol"  
                               x:Name ="txtTitulo"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <Line X1="0" X2="1" Stretch="Fill" Stroke="Gray" StrokeThickness="1"/>

                    <StackPanel Orientation="Horizontal" Spacing="50" HorizontalAlignment="Stretch">
                        <TextBlock>
                            <Run Text="Codigo"/>
                            <Run x:Name="txtCodigo"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Fecha Registro"/>
                            <Run x:Name="txtFecha"/>
                        </TextBlock>
                    </StackPanel>


                    <Line X1="0" X2="1" Stretch="Fill" Stroke="Gray" StrokeThickness="1"/>

                    <!-- Nombre -->
                    <TextBox x:Name="txtNombre"
                             Header="Nombre"/>

                    <TextBox x:Name="txtApellidos"
                             Header="Apellidos"/>

                    <TextBox x:Name="txtUsername"
                             Header="Nombre Usuario"/>
                    
                    <PasswordBox x:Name="pwdPassword"
                                 Header="Contraseña"/>

                    <ComboBox x:Name="cmbRol"
                             Header="Rol"
                             PlaceholderText="Seleccione un rol"/>

                    <ToggleSwitch x:Name="tsEstado"
                                  IsOn="True"
                                  Header="Estado"/>

                    <Line X1="0" X2="1" Stretch="Fill" Stroke="Gray" StrokeThickness="1"/>

                    <!-- BOTONES -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Right">

                        <Button Click="CerrarOverlay_Click" >
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon  Glyph="&#xE711;" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Cancelar"/>
                            </StackPanel>

                        </Button>

                        <Button x:Name="BtnGuardar"
                                Click="GuardarOverlay_Click"
                                Background="#FF2D89EF"
                                Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xF78C;" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock x:Name="txtGuardar" Text="Guardar"/>
                                <ProgressRing x:Name="prCrear"
                                              Width="20"
                                              Height="20"
                                              IsActive="False"
                                              Visibility="Collapsed"/>
                            </StackPanel>



                        </Button>


                    </StackPanel>

                </StackPanel>

            </Border>

        </Grid>
    </Grid>
</Page>

