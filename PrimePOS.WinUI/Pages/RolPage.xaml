<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.RolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d">

    

    
    <Grid Padding="20" RowSpacing="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITULO -->
        <TextBlock
            Text="Gestión de Roles"
            FontSize="28"
            FontWeight="SemiBold"/>

        <!-- FORMULARIO -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="10">

            
            <TextBox
                x:Name="txtNombre"
                 Header="Descripcion"
                 Width="250"/>
            <ToggleSwitch x:Name="tgEstado"
                Header="Estado"
                OnContent="Activo"
                OffContent="Inactivo"
                IsOn="True"/>
            <Button
                Content="Crear"
                Style="{StaticResource AccentButtonStyle}"
                Click="BtnCrearRol_Click"/>

            <Button
                Content="Actualizar"
                Click="BtnActualizarRol_Click"/>

            <Button
                Content="Eliminar"
                Click="BtnEliminarRol_Click"/>
            <Button
                 Content="Limpiar"
                 Click="BtnLimpiar_Click"/>
        </StackPanel>

        <!-- DATAGRID -->
        <controls:DataGrid
            Grid.Row="2"
            x:Name="dgRoles"
            AutoGenerateColumns="False"
            SelectionMode="Single"
            SelectionChanged="dgRoles_SelectionChanged"
            IsReadOnly="True">

            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn
                    Header="RolId"
                    Binding="{Binding RolId}"
                    Width="100"
                    />

                <controls:DataGridTextColumn
                    Header="Nombre"
                    Binding="{Binding Nombre}"
                    Width="100"/>

                <controls:DataGridTextColumn
                    Header="Estado"
                    Binding="{Binding Estado}"
                    Width="*"/>

            </controls:DataGrid.Columns>

        </controls:DataGrid>

    </Grid>

</Page>

