<?xml version="1.0" encoding="utf-8"?>

    <ContentDialog
    x:Class="PrimePOS.WinUI.Pages.TurnoDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Seleccionar Caja y Turno"
    PrimaryButtonText="Confirmar"
    CloseButtonText="Cancelar"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick">

        <StackPanel Spacing="12">

            <ComboBox x:Name="cmbCajas"
                  Header="Caja"
                  DisplayMemberPath="Nombre"
                  SelectionChanged="cmbCajas_SelectionChanged"/>

        <NumberBox
                  x:Name="nbMontoInicial"
                  Header="Monto inicial"
                  PlaceholderText="0.00"/>

        <ComboBox x:Name="cmbTurnos"
                  Header="Turno"
                  DisplayMemberPath="CodigoTurno"/>

        </StackPanel>
    </ContentDialog>

