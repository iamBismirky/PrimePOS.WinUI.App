<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Cards -->
            <RowDefinition Height="*"/>
            <!-- Gráficos y accesos rápidos -->
        </Grid.RowDefinitions>

        <!-- 1️⃣ Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">
            <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold"/>
        </StackPanel>

        <!-- 2️⃣ Cards resumen -->
        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Ventas -->
            <Border Grid.Column="0" Background="#FF2D89EF" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Ventas Hoy" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Total ventas de hoy"/>
                </StackPanel>
            </Border>

            <!-- Card 2: Productos -->
            <Border Grid.Column="1" Background="#FF1E7145" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Productos" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Total Productos"/>
                </StackPanel>
            </Border>

            <!-- Card 3: Clientes -->
            <Border Grid.Column="2" Background="#FFDA532C" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Clientes" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Total Clientes"/>
                </StackPanel>
            </Border>

            <!-- Card 4: Facturas -->
            <Border Grid.Column="3" Background="#FF603CBA" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Facturas Hoy" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Total Facturas hoy"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 3️⃣ Gráficos y accesos rápidos -->
        <Grid Grid.Row="2" ColumnSpacing="20" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <!-- Gráfico -->
                <ColumnDefinition Width="2*"/>
                <!-- Accesos rápidos -->
            </Grid.ColumnDefinitions>

            <!-- Placeholder gráfico de ventas -->
            <Border Grid.Column="0" Background="Transparent" CornerRadius="10" Padding="10">
                <StackPanel>
                    <TextBlock Text="Gráfico de Ventas (mensual)" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Rectangle Fill="#FFB0B0B0" Height="200" RadiusX="5" RadiusY="5"/>
                    <!-- Aquí luego puedes integrar librerías de gráficos como LiveCharts -->
                </StackPanel>
            </Border>

            <!-- Accesos rápidos -->
            <StackPanel Grid.Column="1" Spacing="10">
                <Button Content="Ventas" Height="60" Background="#FF2D89EF" Foreground="White"/>
                <Button Content="Inventario" Height="60" Background="#FF1E7145" Foreground="White"/>
                <Button Content="Clientes" Height="60" Background="#FFDA532C" Foreground="White"/>
                <Button Content="Facturas" Height="60" Background="#FF603CBA" Foreground="White"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>