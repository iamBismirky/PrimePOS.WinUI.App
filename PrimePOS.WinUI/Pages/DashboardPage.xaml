<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.DashboardPage"
    
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">

    <Grid Margin="20">
        <!-- Definimos columnas y filas -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Saludo al usuario -->
        <TextBlock Grid.Column="0" Grid.ColumnSpan="2" FontSize="24" FontWeight="Bold"
                   Text="{Binding UsuarioLoggeado}" Margin="0,0,0,20"/>

        <!-- Ventas del día -->
        <Border Grid.Row="1" Grid.Column="0" CornerRadius="10" Background="White"
                Padding="20" Margin="0,0,20,20" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Ventas del Día" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding VentasDelDiaFormato}"
                           FontSize="28" FontWeight="Bold" Foreground="Green"/>
            </StackPanel>
        </Border>

        <!-- Últimas 5 facturas -->
        <Border Grid.Row="1" Grid.Column="1" CornerRadius="10" Background="White"
                Padding="20" Margin="0,0,0,20" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Últimas 5 Facturas" FontSize="18" FontWeight="SemiBold"/>
                <ListView ItemsSource="{Binding UltimasFacturas}" Margin="0,10,0,0" Height="200">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding NumeroFactura}" Grid.Column="0"/>
                                <TextBlock Text="{Binding Cliente}" Grid.Column="1"/>
                                <!-- Usar conversor en lugar de StringFormat -->
                                <TextBlock Text="{Binding Tota}" Grid.Column="2" HorizontalAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <!-- Calendario -->
        <Border Grid.Row="2" Grid.Column="0" CornerRadius="10" Background="White"
                Padding="20" Margin="0,0,20,0" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Selecciona una Fecha" FontSize="18" FontWeight="SemiBold"/>
                <CalendarDatePicker Margin="0,10,0,0" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>

        <!-- Usuario loggeado -->
        <Border Grid.Row="2" Grid.Column="1" CornerRadius="10" Background="White"
                Padding="20" Margin="0,0,0,0" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Usuario Loggeado" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding UsuarioLoggeado}" FontSize="20" FontWeight="Bold" Margin="0,10,0,0"/>
                <TextBlock Text="{Binding RolUsuario}" FontSize="16" Foreground="Gray"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>   
            
