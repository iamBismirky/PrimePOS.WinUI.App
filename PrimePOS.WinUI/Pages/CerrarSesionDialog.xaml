<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="PrimePOS.WinUI.Pages.CerrarSesionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title=""
    PrimaryButtonText="Cerrar Sesión"
    CloseButtonText="Cancelar"
    DefaultButton="Close"
    CornerRadius="12">

    <Grid Padding="10">

        <StackPanel Spacing="16">

            <!-- ICONO -->
            <Grid Width="60" Height="60"
                  HorizontalAlignment="Center"
                  CornerRadius="30"
                  Background="{ThemeResource AccentFillColorDefaultBrush}">
                <FontIcon Glyph="&#xE748;"/>

            </Grid>

            <!-- TEXTO -->
            <StackPanel Spacing="6" HorizontalAlignment="Center">

                <TextBlock Text="Cerrar sesión"
                           FontSize="20"
                           FontWeight="SemiBold"
                           TextAlignment="Center"/>

                <TextBlock Text="¿Seguro que deseas cerrar sesión?"
                           TextAlignment="Center"
                           Opacity="0.8"
                           TextWrapping="Wrap"/>
            </StackPanel>

        </StackPanel>

    </Grid>


</ContentDialog>
