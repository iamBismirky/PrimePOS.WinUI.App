<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.VentasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI.Pages"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls" 
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:helpers="using:PrimePOS.WinUI.Helpers" 
    Loaded="Page_loaded"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:NumeroConverterHelper x:Key="NumeroConverterHelper"/>
    </Page.Resources>
    <Grid>
        
    <Border  x:Name="panelVentas" Visibility="Visible">
    <Grid Padding="20" RowSpacing="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <!--Header-->

        <StackPanel Grid.Row="0">


            <TextBlock  
                    FontSize="28"
                    FontWeight="Bold"
                    HorizontalAlignment="Left"
                    Text="Ventas"/>

        </StackPanel>
        <!-- Buscador de producto -->
        <Grid Grid.Row="1" ColumnSpacing="20" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="0">

                <controls:WrapPanel Orientation="Vertical" VerticalSpacing="15" >

                    <TextBlock Text="Buscar producto" FontWeight="Bold"  FontFamily="Segoe UI"/>
                        <AutoSuggestBox Grid.Column="0"
                                    x:Name="txtBuscarProducto" 
                                    TextChanged="txtBuscarProducto_TextChanged"
                                    QuerySubmitted="txtBuscarProducto_QuerySubmitted"
                                    SuggestionChosen="txtBuscarProducto_SuggestionChosen"
                                    Width="300"
                                    PlaceholderText="Buscar producto por código o nombre..."
                                    QueryIcon="Find"
                                    UpdateTextOnSelect="False">


                            <AutoSuggestBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding Codigo}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Nombre}"/>
                                        <TextBlock>
                                        <Run Text="$"/>
                                        <Run Text="{Binding PrecioVenta, Converter={StaticResource NumeroConverterHelper}}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </AutoSuggestBox.ItemTemplate>
                        </AutoSuggestBox>

                    </controls:WrapPanel>
            </Border>


            <!--Cliente-->
            <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="1"
                    Width="auto">
                
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                                
                        <controls:WrapPanel Grid.Column="0" Orientation="Vertical" VerticalSpacing="15" >

                            <TextBlock Text="Cliente" FontWeight="Bold"  FontFamily="Segoe UI"/>

                            <AutoSuggestBox Grid.Column="0"
                                            x:Name="txtBuscarCliente" 
                                            TextChanged="txtBuscarCliente_TextChanged"
                                            QuerySubmitted="txtBuscarCliente_QuerySubmitted"
                                            SuggestionChosen="txtBuscarCliente_SuggestionChosen"
                                            PlaceholderText="Buscar cliente por codigo o nombre"
                                            Width="300"
                                            QueryIcon="Find"
                                            UpdateTextOnSelect="False">


                                <AutoSuggestBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{Binding Codigo}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Nombre}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </AutoSuggestBox.ItemTemplate>
                            </AutoSuggestBox>
                        </controls:WrapPanel>
                        
                        <Border Grid.Column="1"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                CornerRadius="10"
                                Padding="15">
                                <controls:WrapPanel Orientation="Vertical" >
                                    <TextBlock>
                                <Run Text="Codigo"/>
                                <Run x:Name="txtCodigoCliente"/>
                                    </TextBlock>
                                    <TextBlock>
                                <Run Text="Nombre"/>
                                <Run x:Name="txtNombreCliente"/>
                                    </TextBlock>
                                    <TextBlock>
                                <Run Text="Documento"/>
                                <Run x:Name="txtDocumentoCliente"/>
                                    </TextBlock>
                                </controls:WrapPanel>
                        </Border>
                       
                    </Grid>
                </Border>

            <!--Metodo de pago-->
            <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="2">

                <controls:WrapPanel Orientation="Vertical" VerticalSpacing="15" >

                    <TextBlock Text="Metodo de Pago" FontWeight="Bold"  FontFamily="Segoe UI"/>
                    <ComboBox x:Name="cmbMetodoPago" SelectedIndex="0"/>

                </controls:WrapPanel>
            </Border>
                <!--Caja-->
                <Border BorderThickness="1"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        CornerRadius="10"
                        Padding="15"
                        Grid.Column="3"
                        Width="200">

                    <controls:WrapPanel Orientation="Vertical" >

                       
                        <TextBlock>
                            <Run Text="Usuario" FontFamily="Segoe UI" FontWeight="Bold"/>
                            <Run x:Name="txtUsuario"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Rol" FontFamily="Segoe UI" FontWeight="Bold"/>
                            <Run x:Name="txtRol"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Caja" FontFamily="Segoe UI" FontWeight="Bold"/>
                            <Run x:Name="txtCaja"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Turno" FontFamily="Segoe UI" FontWeight="Bold"/>
                            <Run x:Name="txtTurno"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Fecha" FontFamily="Segoe UI" FontWeight="Bold"/>
                            <Run x:Name="txtFecha"/>
                        </TextBlock>

                    </controls:WrapPanel>
                </Border>

            </Grid>


        <!--  DataGrid como carrito -->
        <Border Grid.Row="2">
            
            <controls:DataGrid Grid.Row="2" 
                               x:Name="dgCarrito"
                               AutoGenerateColumns="False"
                               SelectionMode="Single"
                               Width="auto"
                               RowHeight="40"
                               ColumnHeaderHeight="40"
                               FontSize="14"
                               IsReadOnly="True">

                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Codigo" Binding="{Binding Codigo}" Width="*"/>
                    <controls:DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <controls:DataGridTextColumn Header="Precio" Binding="{Binding Precio, Converter={StaticResource NumeroConverterHelper}}" Width="*"/>
                    <controls:DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="*"/>
                    <controls:DataGridTextColumn Header="Total" Binding="{Binding Total, Converter={StaticResource NumeroConverterHelper}}" Width="*"/>

                    <controls:DataGridTemplateColumn  Width="*" >
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Click="BtnEliminarProducto_Click"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE74D;"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>
                </controls:DataGrid.Columns>

            </controls:DataGrid>
        </Border>
        <!-- 4️⃣ Totales y botones -->
        <Border Grid.Row="3">
            <Grid Grid.Row="3" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!--Card totales-->
                <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="0">
                    <StackPanel Grid.Column="0" Spacing="5" HorizontalAlignment="Left">

                        <TextBlock>
                                  <Run Text="SubTotal: " FontSize="20" FontWeight="SemiBold" />
                                  <Run FontSize="20" FontWeight="SemiBold"  x:Name="txtSubtotal"/>
                        </TextBlock>

                        <TextBlock>
                                  <Run Text="Impuesto: " FontSize="20" FontWeight="SemiBold" />
                                  <Run FontSize="20" FontWeight="SemiBold"  x:Name="txtImpuesto"/>
                        </TextBlock>

                        <TextBlock>
                                  <Run Text="Descuento: " FontSize="20" FontWeight="SemiBold" />
                                  <Run FontSize="20" FontWeight="SemiBold"  x:Name="txtDescuento"/>
                        </TextBlock>

                        <TextBlock>
                                  <Run Text="Total: " FontSize="24" FontWeight="Bold" />
                                  <Run FontSize="24" FontWeight="SemiBold"  x:Name="txtTotal"/>
                        </TextBlock>

                    </StackPanel>
                </Border>

                <!--Card aplicar descuento-->
                <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="1">
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <TextBlock Text="Aplicar Descuento" FontWeight="Bold"  FontFamily="Segoe UI"/>
                        <ComboBox x:Name="cmbDescuento" 
                                  SelectionChanged="cmbDescuento_SelectionChanged" 
                                  Width="100"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="0%" Tag="0" IsSelected="True"/>
                            <ComboBoxItem Content="5%" Tag="5"/>
                            <ComboBoxItem Content="10%" Tag="10"/>
                            <ComboBoxItem Content="15%" Tag="15"/>
                            <ComboBoxItem Content="20%" Tag="20"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Botones de acción -->
                <Border Grid.Column="2"
                        BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    CornerRadius="10"
                    Padding="15"
                    >
                            <StackPanel Orientation="Vertical" Spacing="10" HorizontalAlignment="Right">
                                <Button Content="Generar Factura" Click="BtnGenerarFactura_Click" Background="#FF2D89EF" Foreground="White"/>
                        <Button Content="Limpiar Pantalla" Click="BtnLimpiar_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
            

        </Grid>
        
    </Border>
        <local:TurnoOverlay x:Name="TurnoOverlay" Visibility="Visible"/>

    </Grid>

</Page>