<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.VentasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls" 
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:helpers="using:PrimePOS.WinUI.Infrastructure"
    Loaded="Page_loaded"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:NumeroConverter x:Key="NumeroConverter"/>
    </Page.Resources>

    <Grid Padding="20" RowSpacing="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--Header-->

        <StackPanel Grid.Row="0">


            <TextBlock  
                    FontSize="28"
                    FontWeight="Bold"
                    HorizontalAlignment="Left"
                    Text="Ventas"/>


            <TextBlock   
                    x:Name="txtFecha"
                    FontSize="16"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Right"
                    Text="Fecha Actual"
                    VerticalAlignment="Center"/>
        </StackPanel>
        <!-- Buscador de producto -->
        <Grid Grid.Row="1" ColumnSpacing="20" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseHighBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="0">

                <controls:WrapPanel Orientation="Vertical" >

                    <TextBlock Text="Buscar producto" FontWeight="Bold"  FontFamily="Segoe UI"/>
                    <AutoSuggestBox Grid.Column="0"
                                    x:Name="txtBuscarProducto" 
                                    TextChanged="txtBuscarProducto_TextChanged"
                                    QuerySubmitted="txtBuscarProducto_QuerySubmitted"
                                    SuggestionChosen="txtBuscarProducto_SuggestionChosen"
                                    Width="300"
                                    PlaceholderText="Buscar producto por código o nombre..."
                                    QueryIcon="Find"
                                    UpdateTextOnSelect="True">


                        <AutoSuggestBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding Codigo}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Nombre}"/>
                                    <TextBlock>
                                        <Run Text="$"/>
                                        <Run Text="{Binding PrecioVenta, Converter={StaticResource NumeroConverter}}"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </AutoSuggestBox.ItemTemplate>
                    </AutoSuggestBox>

                    <Button Grid.Column="1"
                            Content="Agregar al carrito"
                            Click="BtnAgregarProductoCarrito_Click"/>

                </controls:WrapPanel>
            </Border>


            <!--Cliente-->
            <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseHighBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="1"
                    Width="300"
                    Margin="0">

                <controls:WrapPanel Orientation="Vertical" >

                    <TextBlock Text="Cliente" FontWeight="Bold"  FontFamily="Segoe UI"/>
                    <ComboBox x:Name="cmbCliente"  SelectedIndex="0"/>
                    <AutoSuggestBox Grid.Column="0"
                                    x:Name="txtBuscarCliente" 
                                    TextChanged="txtBuscarCliente_TextChanged"
                                    QuerySubmitted="txtBuscarCliente_QuerySubmitted"
                                    SuggestionChosen="txtBuscarCliente_SuggestionChosen"
                                    Width="220"
                                    QueryIcon="Find"
                                    UpdateTextOnSelect="True">


                        <AutoSuggestBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding Codigo}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Nombre}"/>
                                </StackPanel>
                            </DataTemplate>
                        </AutoSuggestBox.ItemTemplate>
                    </AutoSuggestBox>
                </controls:WrapPanel>
            </Border>

            <!--Metodo de pago-->
            <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseHighBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="2">

                <controls:WrapPanel Orientation="Vertical" >

                    <TextBlock Text="Metodo de Pago" FontWeight="Bold"  FontFamily="Segoe UI"/>
                    <ComboBox x:Name="cmbMetodoPago" SelectedIndex="0"/>

                </controls:WrapPanel>
            </Border>

        </Grid>


        <!--  DataGrid como carrito -->
        <Border Grid.Row="2">
            <controls:DataGrid Grid.Row="2" 
                               x:Name="dgCarrito"
                               AutoGenerateColumns="False"
                               SelectionMode="Single"
                               Width="auto"
                               RowHeight="40"
                               ColumnHeaderHeight="40"
                               FontSize="14"
                               IsReadOnly="True">

                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Codigo" Binding="{Binding Codigo}" Width="*"/>
                    <controls:DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <controls:DataGridTextColumn Header="Precio" Binding="{Binding Precio, Converter={StaticResource NumeroConverter}}" Width="*"/>
                    <controls:DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="*"/>
                    <controls:DataGridTextColumn Header="Total" Binding="{Binding Total, Converter={StaticResource NumeroConverter}}" Width="*"/>

                    <controls:DataGridTemplateColumn  Width="*" >
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Click="BtnEliminarProducto_Click"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE74D;"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>
                </controls:DataGrid.Columns>

            </controls:DataGrid>
        </Border>
        <!-- 4️⃣ Totales y botones -->
        <Border Grid.Row="3">
            <Grid Grid.Row="3" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!--Card totales-->
                <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseHighBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="0">
                    <StackPanel Grid.Column="0" Spacing="5" HorizontalAlignment="Left">

                        <TextBlock>
                                  <Run Text="SubTotal: " FontSize="20" FontWeight="SemiBold" />
                                  <Run FontSize="20" FontWeight="SemiBold"  x:Name="txtSubtotal"/>
                        </TextBlock>

                        <TextBlock>
                                  <Run Text="Impuesto: " FontSize="20" FontWeight="SemiBold" />
                                  <Run FontSize="20" FontWeight="SemiBold"  x:Name="txtImpuesto"/>
                        </TextBlock>

                        <TextBlock>
                                  <Run Text="Descuento: " FontSize="20" FontWeight="SemiBold" />
                                  <Run FontSize="20" FontWeight="SemiBold"  x:Name="txtDescuento"/>
                        </TextBlock>

                        <TextBlock>
                                  <Run Text="Total: " FontSize="24" FontWeight="Bold" />
                                  <Run FontSize="24" FontWeight="SemiBold"  x:Name="txtTotal"/>
                        </TextBlock>

                    </StackPanel>
                </Border>

                <!--Card aplicar descuento-->
                <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseHighBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="1">
                    <StackPanel>
                        <TextBlock Text="Aplicar Descuento" FontWeight="Bold"  FontFamily="Segoe UI"/>
                        <ComboBox x:Name="cmbDescuento" SelectionChanged="cmbDescuento_SelectionChanged" Width="100">
                            <ComboBoxItem Content="0%" Tag="0"/>
                            <ComboBoxItem Content="5%" Tag="5"/>
                            <ComboBoxItem Content="10%" Tag="10"/>
                            <ComboBoxItem Content="15%" Tag="15"/>
                            <ComboBoxItem Content="20%" Tag="20"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Botones de acción -->
                <Border Grid.Column="2"
                        BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseHighBrush}"
                    CornerRadius="10"
                    Padding="15"
                    >
                    <StackPanel Orientation="Vertical" Spacing="10" HorizontalAlignment="Right">
                        <Button Content="Borrar Producto" Click="BtnBorrarProducto_Click"/>
                        <Button Content="Generar Factura" Click="BtnGenerarFactura_Click" Background="#FF2D89EF" Foreground="White"/>
                        <Button Content="Limpiar Pantalla" Click="BtnLimpiar_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>

</Page>