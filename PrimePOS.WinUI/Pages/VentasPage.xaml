<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.VentasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI.Pages"
    xmlns:local1="using:PrimePOS.WinUI.ViewModels"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls" 
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:helpers="using:PrimePOS.WinUI.Helpers"
    x:Name="RootPage"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:NumeroConverterHelper x:Key="NumeroConverterHelper"/>
    </Page.Resources>
    <Grid x:Name="RootGrid">

        <Border  x:Name="panelVentas" Visibility="Visible">
                <Grid Padding="20" RowSpacing="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <!--Header-->

        <StackPanel Grid.Row="0">


            <TextBlock  
                    FontSize="28"
                    FontWeight="Bold"
                    HorizontalAlignment="Left"
                    Text="Ventas"/>

        </StackPanel>
         <!--Buscador de producto--> 
        <Grid Grid.Row="1" ColumnSpacing="20" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="0">

                <controls:WrapPanel Orientation="Vertical" VerticalSpacing="15" >

                    <TextBlock Text="Buscar producto" FontWeight="Bold"  FontFamily="Segoe UI"/>
                        <AutoSuggestBox Grid.Column="0"
                                        x:Name="txtBuscarProducto" 
                                        Text="{Binding TextoProducto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{Binding Productos}"
                                        TextChanged="txtBuscarProducto_TextChanged"
                                        QuerySubmitted="txtBuscarProducto_QuerySubmitted"
                                        Width="300"
                                        PlaceholderText="Buscar producto por código o nombre..."
                                        QueryIcon="Find"
                                        UpdateTextOnSelect="False">


                            <AutoSuggestBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding Codigo}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Nombre}"/>
                                        <TextBlock>
                                        <Run Text="$"/>
                                        <Run Text="{Binding PrecioVenta}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </AutoSuggestBox.ItemTemplate>
                        </AutoSuggestBox>

                    </controls:WrapPanel>
            </Border>


            <!--Cliente-->
            <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="1"
                    Width="600">
                
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                                
                        <controls:WrapPanel Grid.Column="0" Orientation="Vertical" VerticalSpacing="15" >

                            <TextBlock Text="Cliente" FontWeight="Bold"  FontFamily="Segoe UI"/>

                            <AutoSuggestBox Grid.Column="0"
                                            x:Name="txtBuscarCliente" 
                                            Text="{Binding TextoCliente, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            ItemsSource="{Binding Clientes}"
                                            TextChanged="txtBuscarCliente_TextChanged"
                                            QuerySubmitted="txtBuscarCliente_QuerySubmitted"
                                            SuggestionChosen="txtBuscarCliente_SuggestionChosen"
                                            PlaceholderText="Buscar cliente por codigo o nombre"
                                            Width="300"
                                            QueryIcon="Find"
                                            UpdateTextOnSelect="False">


                                <AutoSuggestBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{Binding Codigo}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Nombre}"/>
                                            </StackPanel>
                                    </DataTemplate>
                                </AutoSuggestBox.ItemTemplate>
                            </AutoSuggestBox>
                        </controls:WrapPanel>
                        
                        <Border Grid.Column="1"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                CornerRadius="10"
                                Padding="15"
                                Width="250">
                                <controls:WrapPanel Orientation="Vertical" >
                                    <TextBlock>
                                        <Run Text="Cliente: "/>
                                        <Run Text="{Binding ClienteSeleccionado.Codigo}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Nombre: "/>     
                                        <Run Text="{Binding ClienteSeleccionado.Nombre}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Documento: "/>
                                        <Run Text="{Binding ClienteSeleccionado.Documento}"/>
                                    </TextBlock>
                                </controls:WrapPanel>
                        </Border>
                       
                    </Grid>
                </Border>

            <!--Metodo de pago-->
            <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="2">

                <controls:WrapPanel Orientation="Vertical" VerticalSpacing="15" >

                    <TextBlock Text="Metodo de Pago" FontWeight="Bold"  FontFamily="Segoe UI"/>
                            <ComboBox ItemsSource="{Binding MetodosPago}"
                                      SelectedItem="{Binding MetodoPagoSeleccionado, Mode=TwoWay}"
                                      DisplayMemberPath="Nombre" />

                </controls:WrapPanel>
            </Border>
                <!--Caja-->
                <Border BorderThickness="1"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        CornerRadius="10"
                        Padding="15"
                        Grid.Column="3"
                        Width="300">

                    <controls:WrapPanel Orientation="Vertical" >

                       
                        <TextBlock>
                            <Run Text="Usuario" FontFamily="Segoe UI" FontWeight="Bold"/>
                            <Run Text="{Binding AppSesion.TurnoActual.UsuarioNombre, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Rol" FontFamily="Segoe UI" FontWeight="Bold"/>
                            <Run Text="{Binding AppSesion.TurnoActual.RolNombre, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Caja" FontFamily="Segoe UI" FontWeight="Bold"/>
                            <Run Text="{Binding AppSesion.TurnoActual.CajaNombre, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Turno" FontFamily="Segoe UI" FontWeight="Bold"/>
                            <Run Text="{Binding AppSesion.TurnoActual.NumeroTurno, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Fecha Apertura" FontFamily="Segoe UI" FontWeight="Bold"/>
                            <Run Text="{Binding AppSesion.TurnoActual.FechaApertura, Mode=OneWay}"/>
                        </TextBlock>

                    </controls:WrapPanel>
                </Border>

            </Grid>


          <!--DataGrid como carrito--> 
        <Border Grid.Row="2">
            
            <controls:DataGrid Grid.Row="2" 
                               x:Name="dgCarrito"
                               AutoGenerateColumns="False"
                               SelectionMode="Single"
                               Width="auto"
                               RowHeight="40"
                               ColumnHeaderHeight="40"
                               FontSize="14"
                               IsReadOnly="True"
                               ItemsSource="{Binding Carrito, Mode=OneWay}">

                        <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Codigo" Binding="{Binding Codigo}" Width="*"/>
                    <controls:DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <controls:DataGridTextColumn Header="Precio" Binding="{Binding Precio, Converter={StaticResource NumeroConverterHelper}}" Width="*"/>
                    <controls:DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="*"/>
                    <controls:DataGridTextColumn Header="Total" Binding="{Binding Total, Converter={StaticResource NumeroConverterHelper}}" Width="*"/>

                    <controls:DataGridTemplateColumn  Width="*" >
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Click="Eliminar_Click"
                                                    Background="Red"
                                                    Foreground="White"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                    <FontIcon Glyph="&#xE74D;"/>
                                            </Button>
                                </Grid>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>
                </controls:DataGrid.Columns>

            </controls:DataGrid>
        </Border>
         <!--4️⃣ Totales y botones--> 
        <Border Grid.Row="3">
            <Grid Grid.Row="3" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!--Card totales-->
                <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="0">
                    <StackPanel Grid.Column="0" Spacing="5" HorizontalAlignment="Left">

                                <TextBlock>
                                  <Run Text="SubTotal: " FontSize="20" FontWeight="SemiBold" />
                                  <Run Text="{Binding SubtotalConDescuento, Converter={StaticResource NumeroConverterHelper}}" FontSize="20" FontWeight="SemiBold"/>
                                </TextBlock>

                                <TextBlock>
                                  <Run Text="Impuesto: " FontSize="20" FontWeight="SemiBold" />
                                  <Run Text="{Binding Impuesto, Converter={StaticResource NumeroConverterHelper}}" FontSize="20" FontWeight="SemiBold"/>

                                </TextBlock>
                        
                                <TextBlock>
                                  <Run Text="Descuento: " FontSize="20" FontWeight="SemiBold" />
                                  <Run Text="{Binding DescuentoMonto, Converter={StaticResource NumeroConverterHelper}}" FontSize="20" FontWeight="SemiBold"/>
                                </TextBlock>


                                <TextBlock>
                                  <Run Text="Total: " FontSize="24" FontWeight="Bold" />
                                  <Run Text="{Binding Total, Converter={StaticResource NumeroConverterHelper}}"  FontSize="24" FontWeight="SemiBold"/>
                                </TextBlock>
                                

                            </StackPanel>
                </Border>

                <!--Card aplicar descuento-->
                <Border BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    CornerRadius="10"
                    Padding="15"
                    Grid.Column="1">
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <TextBlock Text="Aplicar Descuento" FontWeight="Bold"  FontFamily="Segoe UI"/>
                                <ComboBox x:Name="cmbDescuento" 
                                  Text="{Binding DescuentoPorcentaje, Mode=TwoWay}"
                                  ItemsSource="{Binding Descuentos}"
                                  SelectedItem="{Binding DescuentoSeleccionado, Mode=TwoWay}"
                                  Width="100">
                                </ComboBox>
                    </StackPanel>
                </Border>

                 <!--Botones de acción--> 
                <Border Grid.Column="2"
                        BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    CornerRadius="10"
                    Padding="15"
                    >
                            <StackPanel Orientation="Vertical" Spacing="10" HorizontalAlignment="Right">
                                
                                <Button Content="Limpiar Pantalla" Command="{Binding LimpiarCommand}"/>
                                <Button Content="Cobrar" Command="{Binding CobrarCommand}"/>
                                <Button Content="Abrir Turno" Command="{Binding AbrirTurnoCommand}"/>
                                <Button Content="Cerrar Turno" Command="{Binding CerrarTurnoCommand}"/>
                            </StackPanel>
                </Border>
            </Grid>
        </Border>
            

        </Grid>
        
    </Border>
        <Grid x:Name="OverlayContainer"
              Visibility="Collapsed"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
              Opacity="0.8"/>
        
        <ContentControl x:Name="OverlayContent"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
    </Grid>

</Page>