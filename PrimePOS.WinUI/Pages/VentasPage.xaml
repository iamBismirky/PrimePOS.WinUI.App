<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.VentasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls" xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    
    
        <Grid Padding="20" RowSpacing="15">
            <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock  Grid.Row="0"
                        FontSize="28"
                        FontWeight="Bold"
                        HorizontalAlignment="Left"
                        Text="Ventas"/>
            
           
            <TextBlock  Grid.Row="0" 
                        x:Name="txtFecha"
                        FontSize="16"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Right"
                        Text="Fecha Actual"/>

            <!-- 2️⃣ Buscador de producto -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10">
                
                <AutoSuggestBox
                    x:Name="txtBuscarProducto" 
                    TextChanged="txtBuscarProducto_TextChanged"
                    QuerySubmitted="txtBuscarProducto_QuerySubmitted"
                    KeyDown="txtBuscarProducto_KeyDown"
                    Width="300"
                    PlaceholderText="Buscar producto por código o nombre..." />
                
                <Button Content="Agregar al carrito"
                        Click="BtnAgregarProductoCarrito_Click"/>
                
            </StackPanel>

            <!--  DataGrid como carrito -->
            <controls:DataGrid Grid.Row="2" x:Name="dgCarrito"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  RowHeight="40"
                  ColumnHeaderHeight="40"
                  FontSize="14"
                  ItemsSource="{x:Bind Vm.Carrito}">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Producto" Binding="{Binding ProductoId}" Width="2*"/>
                    <controls:DataGridTextColumn Header="Codigo" Binding="{Binding Codigo}" Width="*"/>
                    <controls:DataGridTextColumn Header="Precio" Binding="{Binding Precio}" Width="*"/>
                    <controls:DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="*"/>
                    <controls:DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="*"/>
                </controls:DataGrid.Columns>
            </controls:DataGrid>

            <!-- 4️⃣ Totales y botones -->
            <Grid Grid.Row="3" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <!-- Totales -->
                    <ColumnDefinition Width="2*"/>
                    <!-- Botones -->
                </Grid.ColumnDefinitions>

                <!-- Totales -->
                <StackPanel Grid.Column="0" Spacing="5" HorizontalAlignment="Left">
                    <TextBlock FontSize="14" Text="{x:Bind Vm.Subtotal}"/>
                    <TextBlock FontSize="14" Text="{x:Bind Vm.Impuesto}"/>
                    <TextBlock FontSize="16" FontWeight="Bold" Text="{x:Bind Vm.Total}"/>
                </StackPanel>

                <!-- Botones de acción -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Content="Borrar Producto" Click="BtnBorrarProducto_Click"/>
                    <Button Content="Generar Factura" Click="BtnGenerarFactura_Click" Background="#FF2D89EF" Foreground="White"/>
                    <Button Content="Limpiar Pantalla" Click="BtnLimpiar_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    
</Page>