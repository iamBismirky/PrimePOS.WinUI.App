<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.VentasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls" xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    
    
        <Grid Padding="20" RowSpacing="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Fecha -->
                <RowDefinition Height="Auto"/>
                <!-- Buscador -->
                <RowDefinition Height="*"/>
                <!-- Carrito -->
                <RowDefinition Height="Auto"/>
                <!-- Totales y botones -->
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0"
                    FontSize="28"
                    FontWeight="Bold"
                    HorizontalAlignment="Left"
                    Text="Ventas"/>
            
            <!-- 1️⃣ Fecha -->
            <TextBlock Grid.Row="0" x:Name="txtFecha"
                   FontSize="16"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Right"
                   Text="Fecha Actual"/>

            <!-- 2️⃣ Buscador de producto -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10">
                <TextBox x:Name="txtBuscarProducto" Width="300"
                     PlaceholderText="Buscar producto por código o nombre..." />
                <Button Content="Agregar al carrito" Click="BtnAgregar_Click"/>
            </StackPanel>

            <!-- 3️⃣ DataGrid como carrito -->
            <controls:DataGrid Grid.Row="2" x:Name="dgCarrito"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  RowHeight="40"
                  ColumnHeaderHeight="40"
                  FontSize="14">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Producto" Binding="{Binding Nombre}" Width="2*"/>
                    <controls:DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="*"/>
                    <controls:DataGridTextColumn Header="Precio Unitario" Binding="{Binding PrecioUnitario}" Width="*"/>
                    <controls:DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal}" Width="*"/>
                    <controls:DataGridTextColumn Header="Categoría" Binding="{Binding NombreCategoria}" Width="*"/>
                </controls:DataGrid.Columns>
            </controls:DataGrid>

            <!-- 4️⃣ Totales y botones -->
            <Grid Grid.Row="3" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <!-- Totales -->
                    <ColumnDefinition Width="2*"/>
                    <!-- Botones -->
                </Grid.ColumnDefinitions>

                <!-- Totales -->
                <StackPanel Grid.Column="0" Spacing="5" HorizontalAlignment="Left">
                    <TextBlock FontSize="14" Text="SubTotal"/>
                    <TextBlock FontSize="14" Text="Impuestos"/>
                    <TextBlock FontSize="16" FontWeight="Bold" Text="Total"/>
                </StackPanel>

                <!-- Botones de acción -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Content="Borrar Producto" Click="BtnBorrarProducto_Click"/>
                    <Button Content="Generar Factura" Click="BtnGenerarFactura_Click" Background="#FF2D89EF" Foreground="White"/>
                    <Button Content="Limpiar Pantalla" Click="BtnLimpiar_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    
</Page>