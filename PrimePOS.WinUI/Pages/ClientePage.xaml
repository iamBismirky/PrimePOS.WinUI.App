<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Pages.ClientePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- CARD FORMULARIO -->
        <Border Grid.Row="0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="12"
            Padding="20">

            <StackPanel Spacing="15">

                <TextBlock Text="Gestión de Clientes"
                       FontSize="24"
                       FontWeight="SemiBold"/>

                <Grid ColumnSpacing="15" RowSpacing="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>


                    <!-- Nombre -->
                    <TextBox x:Name="txtNombre"
                         Header="Nombre"
                         Grid.Row="0"
                         Grid.Column="0"/>

                    <!-- Documento -->
                    <TextBox x:Name="txtDocumento"
                         Header="Documento"
                         Grid.Row="0"
                         Grid.Column="1"/>


                    <!-- Telefono -->
                    <TextBox x:Name="txtTelefono"
                         Header="Teléfono"
                         Grid.Row="1"
                         Grid.Column="0"/>


                    <!-- Email -->
                    <TextBox x:Name="txtEmail"
                         Header="Email"
                         Grid.Row="1"
                         Grid.Column="1"/>


                    <!-- Direccion -->
                    <TextBox x:Name="txtDireccion"
                         Header="Dirección"
                         Grid.Row="2"
                         Grid.Column="0"/>


                    <!-- Estado -->
                    <ToggleSwitch x:Name="tsEstado"
                              Header="Estado"
                              IsOn="True"
                              OnContent="Activo"
                              OffContent="Inactivo"
                              Grid.Row="2"
                              Grid.Column="1"/>

                </Grid>


                <!-- BOTONES -->
                <StackPanel Orientation="Horizontal" Spacing="10">

                    <Button Click="BtnCrear_Click">

                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <SymbolIcon Symbol="Add"/>
                            <TextBlock Text="Crear"/>
                        </StackPanel>

                    </Button>

                    <Button Click="BtnActualizar_Click">

                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <SymbolIcon Symbol="Edit"/>
                            <TextBlock Text="Actualizar"/>
                        </StackPanel>

                    </Button>

                    <Button Click="BtnEliminar_Click">

                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <SymbolIcon Symbol="Delete"/>
                            <TextBlock Text="Eliminar"/>
                        </StackPanel>

                    </Button>

                    <Button Click="BtnLimpiar_Click">

                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <SymbolIcon Symbol="Refresh"/>
                            <TextBlock Text="Limpiar"/>
                        </StackPanel>

                    </Button>

                </StackPanel>

            </StackPanel>

        </Border>



        <!-- CARD DATAGRID -->
        <Border Grid.Row="1"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="12"
            Padding="20">

            <StackPanel Spacing="10">

                <TextBlock Text="Lista de Clientes"
                       FontSize="18"
                       FontWeight="SemiBold"/>

                <controls:DataGrid x:Name="dgClientes"
                      AutoGenerateColumns="False"
                      SelectionChanged="dgClientes_SelectionChanged"
                      SelectionMode="Extended"
                      IsReadOnly="True">

                    <controls:DataGrid.Columns>

                        <controls:DataGridTextColumn Header="Codigo"
                                        Binding="{Binding Codigo}"
                                        Width="auto"/>

                        <controls:DataGridTextColumn Header="Nombre"
                                        Binding="{Binding Nombre}"
                                        Width="auto"/>

                        <controls:DataGridTextColumn Header="Documento"
                                        Binding="{Binding Documento}"
                                        Width="auto"/>

                        <controls:DataGridTextColumn Header="Teléfono"
                                        Binding="{Binding Telefono}"
                                        Width="auto"/>

                        <controls:DataGridTextColumn Header="Email"
                                        Binding="{Binding Email}"
                                        Width="auto"/>

                        <controls:DataGridTextColumn Header="Dirección"
                                        Binding="{Binding Direccion}"
                                        Width="auto"/>

                        <controls:DataGridCheckBoxColumn Header="Estado"
                                       Binding="{Binding Estado}"
                                       Width="auto"/>
                        <controls:DataGridTextColumn Header="Fecha de registro"
                                        Binding="{Binding FechaRegistro}"
                                        Width="auto"/>

                    </controls:DataGrid.Columns>

                </controls:DataGrid>

            </StackPanel>

        </Border>

    </Grid>
</Page>
