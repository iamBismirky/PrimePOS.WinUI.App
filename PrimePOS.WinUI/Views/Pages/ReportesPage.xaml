<Page
    x:Class="PrimePOS.WinUI.Views.Pages.ReportesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>

        <Grid Padding="30" RowSpacing="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Grid.Row="0" Spacing="5">
                <TextBlock Text="Reportes"
                           FontSize="28"
                           FontWeight="Bold"/>
                <TextBlock Text="Análisis de ventas y movimientos"
                           Opacity="0.6"/>
            </StackPanel>

            <!-- FILTROS MODERNOS -->
            <Border Grid.Row="1"
                    CornerRadius="14"
                    Padding="15"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                <controls:WrapPanel HorizontalSpacing="15"
                           VerticalSpacing="10">

                    <!-- TIPO -->
                    <StackPanel>
                        <TextBlock Text="Tipo reporte" Opacity="0.6"/>
                        <ComboBox Width="180"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Ventas"/>
                            <ComboBoxItem Content="Clientes"/>
                            <ComboBoxItem Content="Productos"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- FECHA INICIO -->
                    <StackPanel>
                        <TextBlock Text="Desde" Opacity="0.6"/>
                        <DatePicker Width="160"/>
                    </StackPanel>

                    <!-- FECHA FIN -->
                    <StackPanel>
                        <TextBlock Text="Hasta" Opacity="0.6"/>
                        <DatePicker Width="160"/>
                    </StackPanel>

                    <!-- BOTONES -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="10"
                                VerticalAlignment="Bottom">

                        <Button Content="Generar"
                                Background="#FF2D89EF"
                                Foreground="White"
                                Command="{Binding CargarVentasPorTurnoCommand}"/>

                        <Button Content="Limpiar"
                                Command="{Binding LimpiarCommand}"/>

                    </StackPanel>

                </controls:WrapPanel>
            </Border>

            <!-- KPIS -->
            <controls:WrapPanel Grid.Row="2"
                       HorizontalSpacing="15"
                       VerticalSpacing="15"
                       Margin="0,10,0,10">

                <Border Width="220"
                        Height="100"
                        CornerRadius="12"
                        Padding="15"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Total Ventas" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalVentas}"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Width="220"
                        Height="100"
                        CornerRadius="12"
                        Padding="15"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Registros" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CantidadRegistros}"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Width="220"
                        Height="100"
                        CornerRadius="12"
                        Padding="15"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Promedio" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Promedio}"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

            </controls:WrapPanel>

            <!-- DATA -->
            <Border Grid.Row="3"
                    CornerRadius="14"
                    Padding="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                <controls:DataGrid
                    ItemsSource="{Binding Ventas}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    ColumnHeaderHeight="40"
                    RowHeight="40">

                    <controls:DataGrid.Columns>

                        <controls:DataGridTextColumn Header="ID"
                                                     Binding="{Binding VentaId}" Width="*"/>

                        <controls:DataGridTextColumn Header="Fecha"
                                                     Binding="{Binding FechaRegistro}" Width="2*"/>

                        <controls:DataGridTextColumn Header="Cliente"
                                                     Binding="{Binding ClienteNombre}" Width="3*"/>

                        <controls:DataGridTextColumn Header="Total"
                                                     Binding="{Binding Total}" Width="2*"/>

                    </controls:DataGrid.Columns>

                </controls:DataGrid>

            </Border>

            <!-- EXPORT -->
            <Border Grid.Row="4"
                    Margin="0,10,0,0"
                    Background="Transparent">

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10">

                    <Button Content="Excel"
                            Background="#FF2D89EF"
                            Foreground="White"
                            Click="BtnExportarExcel_Click"/>

                    <Button Content="PDF"
                            Background="#FF1E7145"
                            Foreground="White"
                            Click="BtnExportarPDF_Click"/>

                </StackPanel>

            </Border>

        </Grid>

    </ScrollViewer>

</Page>