<Page
    x:Class="PrimePOS.WinUI.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>

        <Grid Padding="30" RowSpacing="25">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="Dashboard"
                           FontSize="30"
                           FontWeight="Bold"/>

                <TextBlock Text="Resumen general del sistema"
                           Opacity="0.6"/>
            </StackPanel>

            <!-- STATS MODERNAS -->
            <controls:WrapPanel Grid.Row="1"
                       HorizontalSpacing="15"
                       VerticalSpacing="15">

                <!-- CARD -->
                <Border Width="220"
                        Height="120"
                        CornerRadius="14"
                        Padding="15"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                    <StackPanel Spacing="8">
                        <TextBlock Text="Ventas Hoy" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalVentas}"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Ingresos del día" Opacity="0.6" FontSize="11"/>
                    </StackPanel>
                </Border>

                <Border Width="220"
                        Height="120"
                        CornerRadius="14"
                        Padding="15"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                    <StackPanel Spacing="8">
                        <TextBlock Text="Productos" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalProductos}"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                        <TextBlock Text="En inventario" Opacity="0.6" FontSize="11"/>
                    </StackPanel>
                </Border>

                <Border Width="220"
                        Height="120"
                        CornerRadius="14"
                        Padding="15"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                    <StackPanel Spacing="8">
                        <TextBlock Text="Clientes" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalClientes}"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Registrados" Opacity="0.6" FontSize="11"/>
                    </StackPanel>
                </Border>

                <Border Width="220"
                        Height="120"
                        CornerRadius="14"
                        Padding="15"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                    <StackPanel Spacing="8">
                        <TextBlock Text="Facturas" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalFacturas}"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Emitidas hoy" Opacity="0.6" FontSize="11"/>
                    </StackPanel>
                </Border>

            </controls:WrapPanel>

            <!-- ACCESOS RÁPIDOS + ACTIVIDAD -->
            <Grid Grid.Row="2" ColumnSpacing="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ACTIVIDAD (sin gráficos, estilo feed) -->
                <Border Grid.Column="0"
                        CornerRadius="14"
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                    <StackPanel Spacing="15">

                        <TextBlock Text="Actividad reciente"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <StackPanel Spacing="10">

                            <TextBlock Text="✔ Venta #1023 completada"
                                       Opacity="0.8"/>

                            <TextBlock Text="✔ Producto agregado: iPhone 13"
                                       Opacity="0.8"/>

                            <TextBlock Text="✔ Cliente registrado"
                                       Opacity="0.8"/>

                            <TextBlock Text="✔ Caja cerrada correctamente"
                                       Opacity="0.8"/>

                        </StackPanel>

                    </StackPanel>

                </Border>

                <!-- ACCESOS RÁPIDOS -->
                <Border Grid.Column="1"
                        CornerRadius="14"
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                    <StackPanel Spacing="12">

                        <TextBlock Text="Accesos rápidos"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <Button Content="Nueva Venta"
                                Height="45"
                                Background="{StaticResource PrimePOSPrimaryBrush}"
                                Foreground="White"/>

                        <Button Content="Productos"
                                Height="45"/>

                        <Button Content="Clientes"
                                Height="45"/>

                        <Button Content="Reportes"
                                Height="45"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </ScrollViewer>
</Page>