<Page
    x:Class="PrimePOS.WinUI.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>

        <Grid Padding="30" RowSpacing="25">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <!--  HEADER  -->
            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock
                    FontSize="30"
                    FontWeight="Bold"
                    Text="Dashboard" />

                <TextBlock Opacity="0.6" Text="Resumen general del sistema" />
            </StackPanel>

            <!--  STATS MODERNAS  -->
            <controls:WrapPanel
                Grid.Row="1"
                HorizontalSpacing="15"
                VerticalSpacing="15">

                <!--  CARD  -->
                <Border
                    Width="220"
                    Height="120"
                    Padding="15"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="14">

                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Ventas Hoy" />
                        <TextBlock
                            FontSize="22"
                            FontWeight="Bold"
                            Text="{Binding TotalVentas, Converter={StaticResource DecimalToStringConverter}}" />
                        <TextBlock
                            FontSize="11"
                            Opacity="0.6"
                            Text="Ingresos del día" />
                    </StackPanel>
                </Border>
                <Border
                    Width="220"
                    Height="120"
                    Padding="15"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="14">

                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Ventas Hoy" />
                        <TextBlock
                            FontSize="22"
                            FontWeight="Bold"
                            Text="{Binding VentasCount, Converter={StaticResource IntToStringConverter}}" />
                        <TextBlock
                            FontSize="11"
                            Opacity="0.6"
                            Text="Registradas" />
                    </StackPanel>
                </Border>

                <Border
                    Width="220"
                    Height="120"
                    Padding="15"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="14">

                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Productos" />
                        <TextBlock
                            FontSize="22"
                            FontWeight="Bold"
                            Text="{Binding TotalProductos, Converter={StaticResource IntToStringConverter}}" />
                        <TextBlock
                            FontSize="11"
                            Opacity="0.6"
                            Text="En inventario" />
                    </StackPanel>
                </Border>
                <Border
                    Width="220"
                    Height="120"
                    Padding="15"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="14">

                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Clientes" />
                        <TextBlock
                            FontSize="22"
                            FontWeight="Bold"
                            Text="{Binding TotalClientes, Converter={StaticResource IntToStringConverter}}" />
                        <TextBlock
                            FontSize="11"
                            Opacity="0.6"
                            Text="Registrados" />
                    </StackPanel>
                </Border>

                <Border
                    Width="220"
                    Height="120"
                    Padding="15"
                    Background="#E74C3C"
                    CornerRadius="14">

                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Productos Agotados" />
                        <TextBlock
                            FontSize="22"
                            FontWeight="Bold"
                            Text="{Binding TotalAgotados, Converter={StaticResource IntToStringConverter}}" />
                        <TextBlock
                            FontSize="11"
                            Opacity="0.6"
                            Text="Inventario" />
                    </StackPanel>
                </Border>
            </controls:WrapPanel>

            <!--  ACCESOS RÁPIDOS + ACTIVIDAD  -->
            <Grid Grid.Row="2" ColumnSpacing="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  ACTIVIDAD (sin gráficos, estilo feed)  -->

                <Border
                    Grid.Column="0"
                    MaxHeight="300"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="14">

                    <StackPanel Spacing="15">


                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="Actividad reciente" />

                        <StackPanel Spacing="10">
                            <ListView
                                MaxHeight="400"
                                IsItemClickEnabled="False"
                                ItemsSource="{Binding Notifications}"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,10">

                                            <TextBlock FontWeight="Bold" Text="{Binding Title}" />

                                            <TextBlock Text="{Binding Message}" />

                                            <TextBlock FontSize="12" Text="{Binding Fecha}" />

                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                        </StackPanel>


                    </StackPanel>


                </Border>



                <!--  ACCESOS RÁPIDOS  -->
                <Border
                    Grid.Column="1"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="14">

                    <StackPanel Spacing="12">

                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="Accesos rápidos" />

                        <Button
                            Height="45"
                            Background="{StaticResource PrimePOSPrimaryBrush}"
                            Content="Nueva Venta"
                            Foreground="White" />

                        <Button Height="45" Content="Productos" />

                        <Button Height="45" Content="Clientes" />

                        <Button Height="45" Content="Reportes" />

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </ScrollViewer>
</Page>