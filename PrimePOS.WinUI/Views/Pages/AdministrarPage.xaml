<Page
    x:Class="PrimePOS.WinUI.Views.Pages.AdministrarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <Grid Padding="40">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  HEADER  -->
            <StackPanel
                Grid.Row="0"
                Margin="0,0,0,20"
                Spacing="5">
                <TextBlock
                    FontSize="30"
                    FontWeight="Bold"
                    Text="Administración" />

                <TextBlock Opacity="0.6" Text="Gestión de módulos del sistema" />
            </StackPanel>

            <!--  DASHBOARD  -->
            <StackPanel Grid.Row="1" Spacing="30">

                <!--  ADMIN  -->
                <StackPanel Spacing="10">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Opacity="0.7"
                        Text="Administración" />

                    <controls:WrapPanel HorizontalSpacing="15" VerticalSpacing="15">

                        <!--  USUARIOS  -->
                        <Button Click="BtnGestionUsuarios_Click" Style="{StaticResource ButtonRevealStyle}">
                            <Border
                                Width="200"
                                Height="140"
                                Padding="15"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="14">

                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                                    <FontIcon FontSize="34" Glyph="&#xE77B;" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="Usuarios" />
                                    <TextBlock
                                        FontSize="11"
                                        Opacity="0.6"
                                        Text="Gestion de usuarios"
                                        TextAlignment="Center" />
                                </StackPanel>

                            </Border>
                        </Button>

                        <!--  ROLES  -->
                        <Button Click="BtnGestionRoles_Click" Style="{StaticResource ButtonRevealStyle}">
                            <Border
                                Width="200"
                                Height="140"
                                Padding="15"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="14">

                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                                    <FontIcon FontSize="34" Glyph="&#xEBDA;" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="Roles" />
                                    <TextBlock
                                        FontSize="11"
                                        Opacity="0.6"
                                        Text="Permisos y accesos"
                                        TextAlignment="Center" />
                                </StackPanel>

                            </Border>
                        </Button>
                        <Button Click="BtnGestionEmpresa_Click" Style="{StaticResource ButtonRevealStyle}">
                            <Border
                                Width="200"
                                Height="140"
                                Padding="15"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="14">

                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                                    <FontIcon FontSize="34" Glyph="&#xE731;" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="Empresa" />
                                    <TextBlock
                                        FontSize="11"
                                        Opacity="0.6"
                                        Text="Informacion General"
                                        TextAlignment="Center" />
                                </StackPanel>

                            </Border>
                        </Button>
                        <Button Click="Btn_SystemAdministration_Click" Style="{StaticResource ButtonRevealStyle}">
                            <Border
                                Width="200"
                                Height="140"
                                Padding="15"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="14">

                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                                    <FontIcon FontSize="34" Glyph="&#xE912;" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="Administracion del Sistema" />
                                    <TextBlock
                                        FontSize="11"
                                        Opacity="0.6"
                                        Text="Gestiones Adminsitrativas Generales y mas"
                                        TextAlignment="Center" />
                                </StackPanel>

                            </Border>
                        </Button>

                    </controls:WrapPanel>
                </StackPanel>

                <!--  CATALOGO  -->
                <StackPanel Spacing="10">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Opacity="0.7"
                        Text="Catálogo" />

                    <controls:WrapPanel HorizontalSpacing="15" VerticalSpacing="15">

                        <Button Click="BtnGestionProductos_Click" Style="{StaticResource ButtonRevealStyle}">
                            <Border
                                Width="200"
                                Height="140"
                                Padding="15"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="14">
                                <StackPanel HorizontalAlignment="Center" Spacing="8">
                                    <FontIcon FontSize="34" Glyph="&#xEC09;" />
                                    <TextBlock FontWeight="SemiBold" Text="Productos" />
                                    <TextBlock
                                        FontSize="11"
                                        Opacity="0.6"
                                        Text="Inventario"
                                        TextAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Click="BtnGestionCategorias_Click" Style="{StaticResource ButtonRevealStyle}">
                            <Border
                                Width="200"
                                Height="140"
                                Padding="15"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="14">
                                <StackPanel HorizontalAlignment="Center" Spacing="8">
                                    <FontIcon FontSize="34" Glyph="&#xE762;" />
                                    <TextBlock FontWeight="SemiBold" Text="Categorías" />
                                    <TextBlock
                                        FontSize="11"
                                        Opacity="0.6"
                                        Text="Organización"
                                        TextAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Button>

                    </controls:WrapPanel>
                </StackPanel>

                <!--  OPERACION  -->
                <StackPanel Spacing="10">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Opacity="0.7"
                        Text="Operación" />

                    <controls:WrapPanel HorizontalSpacing="15" VerticalSpacing="15">

                        <Button Click="BtnGestionClientes_Click" Style="{StaticResource ButtonRevealStyle}">
                            <Border
                                Width="200"
                                Height="140"
                                Padding="15"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="14">
                                <StackPanel Spacing="8">
                                    <FontIcon FontSize="34" Glyph="&#xE716;" />
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="Clientes"
                                        TextAlignment="Center" />
                                    <TextBlock
                                        FontSize="11"
                                        Opacity="0.6"
                                        Text="Base de clientes"
                                        TextAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Click="BtnGestionCajas_Click" Style="{StaticResource ButtonRevealStyle}">
                            <Border
                                Width="200"
                                Height="140"
                                Padding="15"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="14">
                                <StackPanel Spacing="8">
                                    <FontIcon FontSize="34" Glyph="&#xE7B8;" />
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="Cajas"
                                        TextAlignment="Center" />
                                    <TextBlock
                                        FontSize="11"
                                        Opacity="0.6"
                                        Text="Control de caja"
                                        TextAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Button>

                    </controls:WrapPanel>
                </StackPanel>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>