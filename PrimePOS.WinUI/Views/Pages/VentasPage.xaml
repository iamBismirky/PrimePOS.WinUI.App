<Page
    x:Class="PrimePOS.WinUI.Views.Pages.VentasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    x:Name="RootPage"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <!--  =========================  -->
        <!--  IZQUIERDA  -->
        <!--  =========================  -->

        <Grid Grid.Column="0" RowSpacing="15">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  HEADER  -->
            <StackPanel Grid.Row="0">

                <TextBlock
                    FontSize="32"
                    FontWeight="Bold"
                    Text="Ventas" />

                <TextBlock Opacity="0.7" Text="Punto de venta" />

            </StackPanel>

            <!--  BUSQUEDA  -->
            <Grid Grid.Row="1" ColumnSpacing="15">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!--  PRODUCTOS  -->
                <Border
                    Grid.Column="0"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16">

                    <StackPanel Spacing="12">

                        <TextBlock
                            FontWeight="SemiBold"
                            Opacity="0.7"
                            Text="Buscar producto" />

                        <AutoSuggestBox
                            x:Name="txtBuscarProducto"
                            ItemsSource="{Binding Productos}"
                            PlaceholderText="Código o nombre..."
                            QueryIcon="Find"
                            QuerySubmitted="txtBuscarProducto_QuerySubmitted"
                            Text="{Binding TextoProducto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TextChanged="txtBuscarProducto_TextChanged"
                            UpdateTextOnSelect="False">

                            <AutoSuggestBox.ItemTemplate>
                                <DataTemplate>

                                    <Grid ColumnSpacing="15">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            FontWeight="SemiBold"
                                            Text="{Binding Codigo}" />

                                        <TextBlock Grid.Column="1" Text="{Binding Nombre}" />

                                        <TextBlock Grid.Column="2" Text="{Binding PrecioVenta, Converter={StaticResource NumeroConverterHelper}}" />

                                    </Grid>

                                </DataTemplate>
                            </AutoSuggestBox.ItemTemplate>

                        </AutoSuggestBox>

                    </StackPanel>

                </Border>

                <!--  CLIENTE  -->
                <Border
                    Grid.Column="1"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16">

                    <StackPanel Spacing="12">

                        <TextBlock
                            FontWeight="SemiBold"
                            Opacity="0.7"
                            Text="Cliente" />

                        <AutoSuggestBox
                            x:Name="txtBuscarCliente"
                            ItemsSource="{Binding Clientes}"
                            PlaceholderText="Buscar cliente..."
                            QueryIcon="Find"
                            QuerySubmitted="txtBuscarCliente_QuerySubmitted"
                            SuggestionChosen="txtBuscarCliente_SuggestionChosen"
                            Text="{Binding TextoCliente, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TextChanged="txtBuscarCliente_TextChanged"
                            UpdateTextOnSelect="False">

                            <AutoSuggestBox.ItemTemplate>
                                <DataTemplate>

                                    <StackPanel Orientation="Horizontal" Spacing="10">

                                        <TextBlock FontWeight="SemiBold" Text="{Binding Codigo}" />

                                        <TextBlock Text="{Binding Nombre}" />

                                    </StackPanel>

                                </DataTemplate>
                            </AutoSuggestBox.ItemTemplate>

                        </AutoSuggestBox>

                        <Grid ColumnSpacing="10">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">

                                <TextBlock>
                                    <Run Text="Cliente: " />
                                    <Run Text="{Binding ClienteSeleccionado.Nombre}" />
                                </TextBlock>

                                <TextBlock>
                                    <Run Text="Documento: " />
                                    <Run Text="{Binding ClienteSeleccionado.Documento}" />
                                </TextBlock>
                                <TextBlock>
                                    <Run Text="Tipo: " />
                                    <Run Text="{Binding ClienteSeleccionado.Tipo}" />
                                </TextBlock>

                            </StackPanel>

                            <Button
                                Grid.Column="1"
                                Width="40"
                                Height="40"
                                Command="{Binding NuevoClienteCommand}">

                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE710;" />

                            </Button>

                        </Grid>

                    </StackPanel>

                </Border>

            </Grid>

            <!--  CARRITO  -->
            <Border
                Grid.Row="2"
                Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="16">

                <controls:DataGrid
                    x:Name="dgCarrito"
                    AutoGenerateColumns="False"
                    ColumnHeaderHeight="45"
                    FontSize="14"
                    IsReadOnly="True"
                    ItemsSource="{Binding Carrito}"
                    RowHeight="45"
                    SelectionMode="Single">

                    <controls:DataGrid.Columns>

                        <controls:DataGridTextColumn
                            Width="*"
                            Binding="{Binding Codigo}"
                            Header="Código" />

                        <controls:DataGridTextColumn
                            Width="2*"
                            Binding="{Binding Nombre}"
                            Header="Producto" />

                        <controls:DataGridTextColumn
                            Width="*"
                            Binding="{Binding Cantidad}"
                            Header="Cant." />

                        <controls:DataGridTextColumn
                            Width="*"
                            Binding="{Binding Precio, Converter={StaticResource NumeroConverterHelper}}"
                            Header="Precio" />

                        <controls:DataGridTextColumn
                            Width="*"
                            Binding="{Binding Total, Converter={StaticResource NumeroConverterHelper}}"
                            Header="Total" />

                        <controls:DataGridTemplateColumn Width="90">

                            <controls:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <Button
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="IndianRed"
                                        Click="Eliminar_Click"
                                        Foreground="White">

                                        <FontIcon Glyph="&#xE74D;" />

                                    </Button>

                                </DataTemplate>
                            </controls:DataGridTemplateColumn.CellTemplate>

                        </controls:DataGridTemplateColumn>

                    </controls:DataGrid.Columns>

                </controls:DataGrid>

            </Border>

        </Grid>

        <!--  =========================  -->
        <!--  DERECHA  -->
        <!--  =========================  -->

        <Border
            Grid.Column="1"
            Margin="20,0,0,0"
            Padding="20"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="18">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  INFO  -->
                <StackPanel Grid.Row="0" Spacing="15">

                    <TextBlock
                        FontSize="26"
                        FontWeight="Bold"
                        Text="Resumen" />

                    <Border
                        Padding="15"
                        Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                        CornerRadius="12">

                        <StackPanel Spacing="8">

                            <TextBlock>
                                <Run FontWeight="SemiBold" Text="Usuario: " />

                                <Run Text="{Binding AppSesion.UsuarioActual.UsuarioNombre}" />
                            </TextBlock>

                            <TextBlock>
                                <Run FontWeight="SemiBold" Text="Caja: " />

                                <Run Text="{Binding AppSesion.TurnoActual.CajaNombre}" />
                            </TextBlock>

                            <TextBlock>
                                <Run FontWeight="SemiBold" Text="Turno: " />

                                <Run Text="{Binding AppSesion.TurnoActual.NumeroTurno}" />
                            </TextBlock>

                        </StackPanel>

                    </Border>

                </StackPanel>

                <!--  TOTALES  -->
                <StackPanel
                    Grid.Row="1"
                    VerticalAlignment="Center"
                    Spacing="18">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock FontSize="18" Text="Subtotal" />

                        <TextBlock
                            Grid.Column="1"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="{Binding Subtotal, Converter={StaticResource NumeroConverterHelper}}" />

                    </Grid>

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock FontSize="18" Text="ITBIS" />

                        <TextBlock
                            Grid.Column="1"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="{Binding Impuesto, Converter={StaticResource NumeroConverterHelper}}" />

                    </Grid>

                    <Rectangle
                        Height="1"
                        Margin="0,10"
                        Fill="{ThemeResource SystemControlForegroundBaseLowBrush}" />

                    <StackPanel>

                        <TextBlock
                            FontSize="16"
                            FontWeight="Bold"
                            Opacity="0.7"
                            Text="TOTAL" />

                        <TextBlock
                            FontSize="42"
                            FontWeight="Bold"
                            Text="{Binding Total, Converter={StaticResource NumeroConverterHelper}}" />

                    </StackPanel>

                </StackPanel>

                <!--  BOTONES  -->
                <StackPanel Grid.Row="2" Spacing="12">

                    <Button
                        Height="55"
                        Background="{StaticResource PrimePOSPrimaryBrush}"
                        Command="{Binding CobrarCommand}"
                        Foreground="White">

                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="10">

                            <TextBlock
                                FontSize="18"
                                FontWeight="Bold"
                                Text="Cobrar" />

                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7BF;" />

                        </StackPanel>

                    </Button>

                    <Grid ColumnSpacing="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="0"
                            Command="{Binding LimpiarCommand}"
                            Content="Limpiar" />

                        <Button
                            Grid.Column="1"
                            Command="{Binding AbrirTurnoCommand}"
                            Content="Turno" />
                        <Button
                            Grid.Column="2"
                            Command="{Binding CerrarTurnoCommand}"
                            Content="Cerrar" />

                    </Grid>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Page>