<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrimePOS.WinUI.Views.Pages.FacturasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    x:Name="RootPage"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <!-- ========================= -->
        <!-- IZQUIERDA -->
        <!-- ========================= -->

        <Grid Grid.Column="0" RowSpacing="15">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Grid.Row="0">

                <TextBlock
                    FontSize="32"
                    FontWeight="Bold"
                    Text="Facturas"/>

                <TextBlock
                    Opacity="0.7"
                    Text="Consulta y reimpresión de ventas"/>

            </StackPanel>

            <!-- FILTROS -->
            <Grid
                Grid.Row="1"
                ColumnSpacing="15">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <!-- BUSCAR -->
                <Border
                    Grid.Column="0"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16">

                    <StackPanel Spacing="12">

                        <TextBlock
                            FontWeight="SemiBold"
                            Opacity="0.7"
                            Text="Buscar factura"/>

                        <AutoSuggestBox
                            PlaceholderText="Factura, cliente o teléfono..."
                            QueryIcon="Find"
                            Text="{Binding TextoBusqueda, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    </StackPanel>

                </Border>

                <!-- DESDE -->
                <Border
                    Grid.Column="1"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16">

                    <StackPanel Spacing="12">

                        <TextBlock
                            FontWeight="SemiBold"
                            Opacity="0.7"
                            Text="Desde"/>

                        <DatePicker
                            Date="{Binding FechaDesde, Mode=TwoWay}"/>

                    </StackPanel>

                </Border>

                <!-- HASTA -->
                <Border
                    Grid.Column="2"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16">

                    <StackPanel Spacing="12">

                        <TextBlock
                            FontWeight="SemiBold"
                            Opacity="0.7"
                            Text="Hasta"/>

                        <DatePicker
                            Date="{Binding FechaHasta, Mode=TwoWay}"/>

                    </StackPanel>

                </Border>

                <!-- ESTADO -->
                <Border
                    Grid.Column="3"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16">

                    <StackPanel Spacing="12">

                        <TextBlock
                            FontWeight="SemiBold"
                            Opacity="0.7"
                            Text="Estado"/>

                        <ComboBox
                            ItemsSource="{Binding Estados}"
                            SelectedItem="{Binding EstadoSeleccionado, Mode=TwoWay}"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- LISTADO -->
            <Border
                Grid.Row="2"
                Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="16">

                <Grid RowDefinitions="Auto,*">

                    <!-- HEADER -->
                    <Grid
                        Grid.Row="0"
                        Padding="10,0,10,10"
                        ColumnDefinitions="140,*,140,120,120,120">

                        <TextBlock
                            FontWeight="SemiBold"
                            Text="Factura"/>

                        <TextBlock
                            Grid.Column="1"
                            FontWeight="SemiBold"
                            Text="Cliente"/>

                        <TextBlock
                            Grid.Column="2"
                            FontWeight="SemiBold"
                            Text="Fecha"/>

                        <TextBlock
                            Grid.Column="3"
                            FontWeight="SemiBold"
                            Text="Tipo"/>

                        <TextBlock
                            Grid.Column="4"
                            FontWeight="SemiBold"
                            Text="Estado"/>

                        <TextBlock
                            Grid.Column="5"
                            HorizontalAlignment="Right"
                            FontWeight="SemiBold"
                            Text="Total"/>

                    </Grid>

                    <!-- LISTVIEW -->
                    <ListView
                        Grid.Row="1"
                        ItemsSource="{Binding Facturas}"
                        SelectedItem="{Binding FacturaSeleccionada, Mode=TwoWay}"
                        SelectionMode="Single">

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">

                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>

                            <DataTemplate>

                                <Border
                                    Padding="14"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="10">

                                    <Grid ColumnDefinitions="140,*,140,120,120,120">

                                        <!-- FACTURA -->
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="{Binding NumeroFactura}"/>

                                        <!-- CLIENTE -->
                                        <StackPanel
                                            Grid.Column="1"
                                            Spacing="2">

                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Text="{Binding ClienteNombre}"/>

                                            <TextBlock
                                                FontSize="11"
                                                Opacity="0.6"
                                                Text="{Binding UsuarioNombre}"/>

                                        </StackPanel>

                                        <!-- FECHA -->
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Text="{Binding Fecha}"/>

                                        <!-- TIPO -->
                                        <Border
                                            Grid.Column="3"
                                            Padding="10,5"
                                            HorizontalAlignment="Left"
                                            Background="#2A2A2A"
                                            CornerRadius="999">

                                            <TextBlock
                                                Text="{Binding TipoVenta}"/>

                                        </Border>

                                        <!-- ESTADO -->
                                        <Border
                                            Grid.Column="4"
                                            Padding="10,5"
                                            HorizontalAlignment="Left"
                                            Background="#1E4D2B"
                                            CornerRadius="999">

                                            <TextBlock
                                                Foreground="White"
                                                Text="{Binding Estado}"/>

                                        </Border>

                                        <!-- TOTAL -->
                                        <TextBlock
                                            Grid.Column="5"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontWeight="Bold"
                                            FontSize="16"
                                            Text="{Binding Total, Converter={StaticResource NumeroConverterHelper}}"/>

                                    </Grid>

                                </Border>

                            </DataTemplate>

                        </ListView.ItemTemplate>

                    </ListView>

                </Grid>

            </Border>

        </Grid>

        <!-- ========================= -->
        <!-- DERECHA -->
        <!-- ========================= -->

        <Border
            Grid.Column="1"
            Margin="20,0,0,0"
            Padding="20"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="18">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <StackPanel Grid.Row="0" Spacing="15">

                    <TextBlock
                        FontSize="26"
                        FontWeight="Bold"
                        Text="Detalle"/>

                    <Border
                        Padding="15"
                        Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                        CornerRadius="12">

                        <StackPanel Spacing="8">

                            <TextBlock>
                                <Run FontWeight="SemiBold" Text="Factura: "/>
                                <Run Text="{Binding FacturaSeleccionada.NumeroFactura}"/>
                            </TextBlock>

                            <TextBlock>
                                <Run FontWeight="SemiBold" Text="Cliente: "/>
                                <Run Text="{Binding FacturaSeleccionada.ClienteNombre}"/>
                            </TextBlock>

                            <TextBlock>
                                <Run FontWeight="SemiBold" Text="Fecha: "/>
                                <Run Text="{Binding FacturaSeleccionada.Fecha}"/>
                            </TextBlock>

                            <TextBlock>
                                <Run FontWeight="SemiBold" Text="Usuario: "/>
                                <Run Text="{Binding FacturaSeleccionada.UsuarioNombre}"/>
                            </TextBlock>

                        </StackPanel>

                    </Border>

                </StackPanel>

                <!-- DETALLE -->
                <StackPanel
                    Grid.Row="1"
                    VerticalAlignment="Top"
                    Spacing="18">

                    <!-- PRODUCTOS -->
                    <Border
                        Padding="15"
                        Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                        CornerRadius="12">

                        <StackPanel Spacing="12">

                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="Productos"/>

                            <ItemsControl
                                ItemsSource="{Binding FacturaSeleccionada.Detalles}">

                                <ItemsControl.ItemTemplate>

                                    <DataTemplate>

                                        <Grid Margin="0,0,0,10">

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>

                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Text="{Binding NombreProducto}"/>

                                                <TextBlock
                                                    FontSize="11"
                                                    Opacity="0.6"
                                                    Text="{Binding Cantidad}"/>

                                            </StackPanel>

                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                FontWeight="SemiBold"
                                                Text="{Binding Total, Converter={StaticResource NumeroConverterHelper}}"/>

                                        </Grid>

                                    </DataTemplate>

                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </StackPanel>

                    </Border>

                    <!-- TOTALES -->
                    <Border
                        Padding="15"
                        Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                        CornerRadius="12">

                        <StackPanel Spacing="14">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock FontSize="18" Text="Subtotal"/>

                                <TextBlock
                                    Grid.Column="1"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="{Binding FacturaSeleccionada.Subtotal, Converter={StaticResource NumeroConverterHelper}}"/>

                            </Grid>

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock FontSize="18" Text="ITBIS"/>

                                <TextBlock
                                    Grid.Column="1"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="{Binding FacturaSeleccionada.Impuesto, Converter={StaticResource NumeroConverterHelper}}"/>

                            </Grid>

                            <Rectangle
                                Height="1"
                                Margin="0,5"
                                Fill="{ThemeResource SystemControlForegroundBaseLowBrush}"/>

                            <StackPanel>

                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Opacity="0.7"
                                    Text="TOTAL"/>

                                <TextBlock
                                    FontSize="38"
                                    FontWeight="Bold"
                                    Text="{Binding FacturaSeleccionada.Total, Converter={StaticResource NumeroConverterHelper}}"/>

                            </StackPanel>

                        </StackPanel>

                    </Border>

                </StackPanel>

                <!-- BOTONES -->
                <StackPanel
                    Grid.Row="2"
                    Spacing="12">

                    <!-- VER PDF -->
                    <Button
                        Height="55"
                        Background="{StaticResource PrimePOSPrimaryBrush}"
                        Command="{Binding VerFacturaCommand}"
                        Foreground="White">

                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="10">

                            <TextBlock
                                FontSize="18"
                                FontWeight="Bold"
                                Text="Ver PDF"/>

                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                Glyph="&#xE8A5;"/>

                        </StackPanel>

                    </Button>

                    <!-- BOTONES SECUNDARIOS -->
                    <Grid ColumnSpacing="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="0"
                            Command="{Binding ReimprimirFacturaCommand}"
                            Content="Reimprimir"/>

                        <Button
                            Grid.Column="1"
                            Command="{Binding AnularFacturaCommand}"
                            Content="Anular"/>

                    </Grid>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Page>
