<Page
    x:Class="PrimePOS.WinUI.Views.Pages.PerfilPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="30">

        <Border
            MaxWidth="700"
            Padding="25"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="18">

            <Grid ColumnSpacing="25">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <!--  ================= LEFT: PERFIL =================  -->
                <StackPanel Spacing="15">

                    <!--  AVATAR  -->
                    <Grid
                        Width="100"
                        Height="100"
                        HorizontalAlignment="Left">

                        <Ellipse Fill="{ThemeResource AccentFillColorDefaultBrush}" />

                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="42"
                            Foreground="White"
                            Glyph="&#xE77B;" />
                    </Grid>

                    <!--  INFO  -->
                    <TextBlock
                        FontSize="26"
                        FontWeight="Bold"
                        Text="Mi Perfil" />

                    <TextBlock Opacity="0.6" Text="Información de la cuenta" />

                    <StackPanel Spacing="10">

                        <StackPanel>
                            <TextBlock Opacity="0.6" Text="Usuario" />
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="{Binding UsuarioNombre}" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Opacity="0.6" Text="Rol" />
                            <TextBlock Text="{Binding UsuarioRol}" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Opacity="0.6" Text="Username" />
                            <TextBlock Text="{Binding Username}" />
                        </StackPanel>

                    </StackPanel>

                </StackPanel>

                <!--  ================= RIGHT: SEGURIDAD =================  -->
                <StackPanel Grid.Column="1" Spacing="15">

                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="Seguridad" />

                    <TextBlock Opacity="0.6" Text="Cambiar contraseña" />

                    <!--  CARD PASSWORD  -->
                    <Border
                        Padding="15"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        CornerRadius="12">

                        <StackPanel Spacing="12">

                            <PasswordBox
                                Password="{Binding PasswordActual, Mode=TwoWay}"
                                PasswordChanged="Actual_PasswordChanged"
                                PlaceholderText="Contraseña actual" />

                            <PasswordBox
                                Password="{Binding PasswordNueva, Mode=TwoWay}"
                                PasswordChanged="Nueva_PasswordChanged"
                                PlaceholderText="Nueva contraseña" />

                            <PasswordBox
                                Password="{Binding Confirmar, Mode=TwoWay}"
                                PasswordChanged="Confirmar_PasswordChanged"
                                PlaceholderText="Confirmar contraseña" />

                        </StackPanel>

                    </Border>

                    <!--  BOTÓN  -->
                    <Button
                        Height="45"
                        Command="{Binding CambiarPasswordCommand}"
                        Content="Actualizar contraseña"
                        Style="{ThemeResource AccentButtonStyle}" />

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Page>