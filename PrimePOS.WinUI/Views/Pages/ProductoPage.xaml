<Page
    x:Class="PrimePOS.WinUI.Views.Pages.ProductoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Grid
        x:Name="MainRoot"
        Padding="25"
        RowSpacing="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ================================================= -->
        <!-- HEADER -->
        <!-- ================================================= -->

        <Border Padding="10,5,10,10">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="5">

                    <TextBlock
                        FontSize="32"
                        FontWeight="Bold"
                        Text="Productos" />

                    <TextBlock
                        Opacity="0.6"
                        Text="Gestiona inventario, precios y disponibilidad" />

                </StackPanel>

                <Button
                    Grid.Column="1"
                    Padding="25,10"
                    Background="{StaticResource PrimePOSPrimaryBrush}"
                    Command="{Binding NuevoCommand}"
                    Foreground="White">

                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8">

                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            Glyph="&#xE710;" />

                        <TextBlock Text="Nuevo" />

                    </StackPanel>

                </Button>

            </Grid>

        </Border>

        <!-- ================================================= -->
        <!-- TOOLBAR -->
        <!-- ================================================= -->

        <Border
            Grid.Row="1"
            Padding="15"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="14">

            <Grid ColumnSpacing="15">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    PlaceholderText="Buscar productos por código, nombre o categoría..."
                    Text="{Binding Buscar, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <Button
                    Grid.Column="1"
                    Command="{Binding FiltrarCommand}">

                    <FontIcon
                        FontSize="18"
                        Glyph="&#xE721;" />

                </Button>

            </Grid>

        </Border>

        <!-- ================================================= -->
        <!-- PRODUCTOS -->
        <!-- ================================================= -->

        <Border
            Grid.Row="2"
            Padding="15"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="16">

            <Grid RowSpacing="10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" /> 
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="Productos" />

                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Opacity="0.6"
                        Text="{Binding Productos.Count}" />

                </Grid>

                <!-- LISTADO -->
                <Grid Grid.Row="1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- COLUMNAS -->
                    <Grid
                        Padding="10,0,10,10"
                        ColumnDefinitions="100,*,120,100,180">

                        <TextBlock
                            FontWeight="SemiBold"
                            Text="Código"/>

                        <TextBlock
                            Grid.Column="1"
                            FontWeight="SemiBold"
                            Text="Producto"/>

                        <TextBlock
                            Grid.Column="2"
                            FontWeight="SemiBold"
                            Text="Categoría"/>

                        <TextBlock
                            Grid.Column="3"
                            HorizontalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="Stock"/>

                        <TextBlock
                            Grid.Column="4"
                            HorizontalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="Acciones"/>

                    </Grid>

                    <!-- CONTENIDO -->
                    <Grid Grid.Row="1">

                        <!-- LISTVIEW -->
                        <ListView
                            ItemsSource="{Binding Productos}"
                            IsItemClickEnabled="False"
                            SelectionMode="Single">

                            <ListView.ItemContainerStyle>

                                <Style TargetType="ListViewItem">

                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

                                </Style>

                            </ListView.ItemContainerStyle>

                            <ListView.ItemTemplate>

                                <DataTemplate>

                                    <Border
                                        Padding="12"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        CornerRadius="12">

                                        <Grid ColumnDefinitions="100,*,120,100,180">

                                            <!-- CODIGO -->
                                            <StackPanel
                                                VerticalAlignment="Center">

                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Codigo}"/>

                                                <TextBlock
                                                    FontSize="11"
                                                    Opacity="0.6"
                                                    Text="{Binding CodigoBarra}"/>

                                            </StackPanel>

                                            <!-- PRODUCTO -->
                                            <StackPanel
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Spacing="2">

                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Nombre}"
                                                    TextTrimming="CharacterEllipsis"/>

                                                <TextBlock
                                                    FontSize="11"
                                                    MaxLines="1"
                                                    Opacity="0.6"
                                                    Text="{Binding Descripcion}"
                                                    TextTrimming="CharacterEllipsis"/>

                                            </StackPanel>

                                            <!-- CATEGORIA -->
                                            <TextBlock
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                Text="{Binding CategoriaNombre}"/>

                                            <!-- STOCK -->
                                            <Border
                                                Grid.Column="3"
                                                Padding="10,4"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="#1E4D2B"
                                                CornerRadius="999">

                                                <TextBlock
                                                    Foreground="White"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Existencia}"/>

                                            </Border>

                                            <!-- ACCIONES -->
                                            <StackPanel
                                                Grid.Column="4"
                                                HorizontalAlignment="Center"
                                                Orientation="Horizontal"
                                                Spacing="8">

                                                <!-- EDITAR -->
                                                <Button
                                                    Width="40"
                                                    Height="40"
                                                    Background="{StaticResource PrimePOSPrimaryBrush}"
                                                    Click="Editar_Click"
                                                    Tag="{Binding}">

                                                    <FontIcon
                                                        Foreground="White"
                                                        Glyph="&#xE70F;" />

                                                </Button>

                                                <!-- ETIQUETA -->
                                                <Button
                                                    Width="40"
                                                    Height="40"
                                                    Click="VerEtiqueta_Click"
                                                    Tag="{Binding}">

                                                    <FontIcon
                                                        Glyph="&#xE8A5;" />

                                                </Button>

                                                <!-- DESACTIVAR -->
                                                <Button
                                                    Width="40"
                                                    Height="40"
                                                    Background="{StaticResource PrimePOSDangerBrush}"
                                                    Click="Desactivar_Click"
                                                    Tag="{Binding}">

                                                    <FontIcon
                                                        Foreground="White"
                                                        Glyph="&#xE74D;" />

                                                </Button>

                                            </StackPanel>

                                        </Grid>

                                    </Border>

                                </DataTemplate>

                            </ListView.ItemTemplate>

                        </ListView>

                        <!-- LOADING OVERLAY -->
                        <Grid
                            Background="#66000000"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">

                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="12">

                                <ProgressRing
                                    Width="50"
                                    Height="50"
                                    IsActive="True"/>

                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="Cargando productos..."/>

                            </StackPanel>

                        </Grid>

                    </Grid>

                </Grid>

            </Grid>

        </Border>

    </Grid>

</Page>