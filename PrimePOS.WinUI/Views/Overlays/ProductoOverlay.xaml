<UserControl
    x:Class="PrimePOS.WinUI.Views.Overlays.ProductoOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}">

        <Border
            Width="1180"
            MaxHeight="820"
            Padding="22"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{ThemeResource SolidBackgroundFillColorBase}"
            CornerRadius="18">

            <Grid RowSpacing="18">

                <!--  ================= ROWS =================  -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  ================= HEADER =================  -->
                <Grid Grid.Row="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">

                        <TextBlock
                            FontSize="26"
                            FontWeight="SemiBold"
                            Text="Producto" />

                        <TextBlock Opacity="0.7" Text="Gestión de información, inventario y precios" />

                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Padding="10,0.5"
                        Background="{ThemeResource AccentFillColorSecondaryBrush}"
                        CornerRadius="10">

                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="8">

                            <FontIcon Glyph="&#xE8EC;" />

                            <TextBlock FontWeight="SemiBold" Text="{Binding Codigo}" />

                        </StackPanel>

                    </Border>

                </Grid>

                <!--  ================= BODY =================  -->
                <Grid Grid.Row="1" ColumnSpacing="18">

                    <!--  ================= COLUMNS =================  -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <!--  =================================================  -->
                    <!--  ================= INFORMACION ===================  -->
                    <!--  =================================================  -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">

                        <Border
                            Width="400"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="16">

                            <StackPanel Spacing="14">

                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="Información general" />

                                <Border
                                    Height="1"
                                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    Opacity="0.4" />


                                <StackPanel Spacing="4">

                                    <TextBlock Opacity="0.7" Text="Fecha Registro" />

                                    <TextBlock FontWeight="SemiBold" Text="{Binding FechaRegistro, Converter={StaticResource DateFormatConverter}}" />

                                </StackPanel>

                                <TextBox
                                    Header="Nombre"
                                    PlaceholderText="Nombre del producto"
                                    Text="{Binding Nombre, Mode=TwoWay}" />

                                <TextBox
                                    MinHeight="100"
                                    VerticalContentAlignment="Top"
                                    AcceptsReturn="True"
                                    Header="Descripción"
                                    PlaceholderText="Descripción del producto"
                                    Text="{Binding Descripcion, Mode=TwoWay}"
                                    TextWrapping="Wrap" />

                                <TextBox
                                    Header="Código de barras"
                                    PlaceholderText="Código de barras"
                                    Text="{Binding CodigoBarra, Mode=TwoWay}" />

                                <StackPanel
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal"
                                    Spacing="8">

                                    <ComboBox
                                        DisplayMemberPath="Nombre"
                                        Header="Categoría"
                                        ItemsSource="{Binding Categorias}"
                                        PlaceholderText="Seleccione una categoría"
                                        SelectedItem="{Binding CategoriaSeleccionada, Mode=TwoWay}" />

                                    <Button
                                        Width="40"
                                        Height="40"
                                        HorizontalAlignment="Left"
                                        Command="{Binding NuevaCategoriaCommand}">

                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE710;" />

                                    </Button>

                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                    <ScrollViewer Grid.Column="1">

                        <Grid Grid.Column="1" RowSpacing="18">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  =================================================  -->
                            <!--  ================= CONFIGURACION =================  -->
                            <!--  =================================================  -->
                            <Border
                                Grid.Row="0"
                                Padding="18"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="18">

                                <StackPanel Spacing="18">

                                    <StackPanel Spacing="4">

                                        <TextBlock
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Text="Configuración" />

                                        <TextBlock Opacity="0.7" Text="Inventario, ganancias y comportamiento del producto" />

                                    </StackPanel>

                                    <Border
                                        Height="1"
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        Opacity="0.4" />

                                    <Grid ColumnSpacing="16" RowSpacing="16">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!--  PRECIO COMPRA  -->

                                        <TextBox
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Header="Precio compra"
                                            PlaceholderText="0.00"
                                            Text="{Binding PrecioCompra, Mode=TwoWay, Converter={StaticResource DecimalToStringConverter}, UpdateSourceTrigger=PropertyChanged}" />

                                        <!--  EXISTENCIA  -->

                                        <NumberBox
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Header="Existencia"
                                            SpinButtonPlacementMode="Compact"
                                            Value="{Binding Existencia, Mode=TwoWay}" />

                                        <!--  GANANCIA MINORISTA  -->

                                        <TextBox
                                            Grid.Row="0"
                                            Grid.Column="2"
                                            Header="Ganancia Minorista %"
                                            IsEnabled="{Binding PrecioAutomatico, Converter={StaticResource InverseBooleanConverter}}"
                                            PlaceholderText="0"
                                            Text="{Binding PorcentajeGananciaMinorista, Mode=TwoWay, Converter={StaticResource DecimalToStringConverter}, UpdateSourceTrigger=PropertyChanged}" />

                                        <!--  GANANCIA MAYORISTA  -->

                                        <TextBox
                                            Grid.Row="0"
                                            Grid.Column="3"
                                            Header="Ganancia Mayorista %"
                                            IsEnabled="{Binding PrecioAutomatico, Converter={StaticResource InverseBooleanConverter}}"
                                            PlaceholderText="0"
                                            Text="{Binding PorcentajeGananciaMayorista, Mode=TwoWay, Converter={StaticResource DecimalToStringConverter}, UpdateSourceTrigger=PropertyChanged}" />

                                        <!--  TOGGLES  -->

                                        <Border
                                            Grid.Row="1"
                                            Grid.ColumnSpan="4"
                                            Padding="16"
                                            Background="{ThemeResource LayerFillColorAltBrush}"
                                            CornerRadius="14">

                                            <StackPanel Orientation="Horizontal" Spacing="30">

                                                <ToggleSwitch Header="Precio automático" IsOn="{Binding PrecioAutomatico, Mode=TwoWay}" />

                                                <ToggleSwitch Header="Aplicar ITBIS" IsOn="{Binding AplicaItbis, Mode=TwoWay}" />

                                                <ToggleSwitch Header="Producto activo" IsOn="{Binding Estado, Mode=TwoWay}" />

                                            </StackPanel>

                                        </Border>

                                    </Grid>

                                </StackPanel>

                            </Border>

                            <!--  =================================================  -->
                            <!--  ================= PRECIOS =======================  -->
                            <!--  =================================================  -->

                            <Grid
                                Grid.Row="1"
                                Margin="0,4,0,0"
                                ColumnSpacing="18">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  =================================================  -->
                                <!--  ================= MINORISTA =====================  -->
                                <!--  =================================================  -->

                                <Border
                                    Grid.Column="0"
                                    Padding="22"
                                    Background="#1E3A5F"
                                    CornerRadius="18">

                                    <StackPanel Spacing="18">

                                        <StackPanel Orientation="Horizontal" Spacing="10">

                                            <FontIcon Foreground="White" Glyph="&#xE719;" />

                                            <TextBlock
                                                FontSize="20"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="Precio Minorista" />

                                        </StackPanel>

                                        <Border
                                            Height="1"
                                            Background="White"
                                            Opacity="0.15" />

                                        <Border
                                            Padding="18"
                                            Background="#2A4F7A"
                                            CornerRadius="16">

                                            <StackPanel Spacing="6">

                                                <TextBlock
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Foreground="#90CAF9"
                                                    Text="PRECIO FINAL" />

                                                <TextBlock
                                                    Foreground="#D6E4F0"
                                                    Opacity="0.8"
                                                    Text="Precio Minorista" />

                                                <TextBlock
                                                    FontSize="34"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="{Binding PrecioFinalMinorista, Converter={StaticResource NumeroConverterHelper}}" />

                                            </StackPanel>

                                        </Border>

                                        <Grid RowSpacing="14">

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Grid.Row="0"
                                                Foreground="#D6E4F0"
                                                Text="Precio base" />

                                            <TextBlock
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding PrecioBase, Converter={StaticResource NumeroConverterHelper}}" />

                                            <TextBlock
                                                Grid.Row="1"
                                                Foreground="#D6E4F0"
                                                Text="ITBIS" />

                                            <TextBlock
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding Itbis, Converter={StaticResource NumeroConverterHelper}}" />

                                            <TextBlock
                                                Grid.Row="2"
                                                Foreground="#D6E4F0"
                                                Text="Ganancia" />

                                            <TextBlock
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding Ganancia, Converter={StaticResource NumeroConverterHelper}}" />

                                            <TextBlock
                                                Grid.Row="3"
                                                Foreground="#D6E4F0"
                                                Text="Porcentaje" />

                                            <TextBlock
                                                Grid.Row="3"
                                                Grid.Column="1"
                                                FontWeight="SemiBold"
                                                Foreground="White">

                                                <Run Text="{Binding PorcentajeGananciaMinorista}" />
                                                <Run Text="%" />

                                            </TextBlock>

                                        </Grid>

                                    </StackPanel>

                                </Border>

                                <!--  =================================================  -->
                                <!--  ================= MAYORISTA =====================  -->
                                <!--  =================================================  -->

                                <Border
                                    Grid.Column="1"
                                    Padding="22"
                                    Background="#14532D"
                                    CornerRadius="18">

                                    <StackPanel Spacing="18">

                                        <StackPanel Orientation="Horizontal" Spacing="10">

                                            <FontIcon Foreground="White" Glyph="&#xE719;" />

                                            <TextBlock
                                                FontSize="20"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="Precio Mayorista" />

                                        </StackPanel>

                                        <Border
                                            Height="1"
                                            Background="White"
                                            Opacity="0.15" />

                                        <Border
                                            Padding="18"
                                            Background="#1F7A45"
                                            CornerRadius="16">

                                            <StackPanel Spacing="6">

                                                <TextBlock
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Foreground="#A7F3D0"
                                                    Text="PRECIO FINAL" />

                                                <TextBlock
                                                    Foreground="#D8F3DC"
                                                    Opacity="0.8"
                                                    Text="Precio Mayorista" />

                                                <TextBlock
                                                    FontSize="34"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="{Binding PrecioFinalMayorista, Converter={StaticResource NumeroConverterHelper}}" />

                                            </StackPanel>

                                        </Border>

                                        <Grid RowSpacing="14">

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Grid.Row="0"
                                                Foreground="#D8F3DC"
                                                Text="Precio base" />

                                            <TextBlock
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding PrecioBaseMayorista, Converter={StaticResource NumeroConverterHelper}}" />

                                            <TextBlock
                                                Grid.Row="1"
                                                Foreground="#D8F3DC"
                                                Text="ITBIS" />

                                            <TextBlock
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding Itbis, Converter={StaticResource NumeroConverterHelper}}" />

                                            <TextBlock
                                                Grid.Row="2"
                                                Foreground="#D8F3DC"
                                                Text="Ganancia" />

                                            <TextBlock
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding GananciaMayorista, Converter={StaticResource NumeroConverterHelper}}" />

                                            <TextBlock
                                                Grid.Row="3"
                                                Foreground="#D8F3DC"
                                                Text="Porcentaje" />

                                            <TextBlock
                                                Grid.Row="3"
                                                Grid.Column="1"
                                                FontWeight="SemiBold"
                                                Foreground="White">

                                                <Run Text="{Binding PorcentajeGananciaMayorista}" />
                                                <Run Text="%" />

                                            </TextBlock>

                                        </Grid>

                                    </StackPanel>

                                </Border>

                            </Grid>


                        </Grid>
                    </ScrollViewer>


                    <!--  =================================================  -->
                    <!--  ================= CONFIG ========================  -->
                    <!--  =================================================  -->



                </Grid>

                <!--  ================= ACTIONS =================  -->
                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="12">

                    <Button
                        Command="{Binding CancelarCommand}"
                        Content="Cancelar"
                        Style="{ThemeResource ButtonRevealStyle}" />

                    <Button MinWidth="140" Command="{Binding GuardarCommand}">

                        <StackPanel Orientation="Horizontal" Spacing="10">

                            <FontIcon Glyph="&#xF78C;" />

                            <TextBlock Text="Guardar" />

                            <ProgressRing
                                Width="18"
                                Height="18"
                                IsActive="{Binding IsLoading}"
                                Visibility="{Binding IsLoading}" />

                        </StackPanel>

                    </Button>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</UserControl>