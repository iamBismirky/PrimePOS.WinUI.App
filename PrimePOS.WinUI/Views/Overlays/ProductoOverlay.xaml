<UserControl
    x:Class="PrimePOS.WinUI.Views.Overlays.ProductoOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}">

        <Border
            Width="1180"
            MaxHeight="820"
            Padding="22"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{ThemeResource SolidBackgroundFillColorBase}"
            CornerRadius="18">

            <Grid RowSpacing="18">

                <!--  ================= ROWS =================  -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  ================= HEADER =================  -->
                <Grid Grid.Row="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">

                        <TextBlock
                            FontSize="26"
                            FontWeight="SemiBold"
                            Text="Producto" />

                        <TextBlock Opacity="0.7" Text="Gestión de información, inventario y precios" />

                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Padding="10,0.5"
                        Background="{ThemeResource AccentFillColorSecondaryBrush}"
                        CornerRadius="10">

                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="8">

                            <FontIcon Glyph="&#xE8EC;" />

                            <TextBlock FontWeight="SemiBold" Text="{Binding Codigo}" />

                        </StackPanel>

                    </Border>

                </Grid>

                <!--  ================= BODY =================  -->
                <Grid Grid.Row="1" ColumnSpacing="18">

                    <!--  ================= COLUMNS =================  -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2.4*" />
                        <ColumnDefinition Width="2.4*" />
                    </Grid.ColumnDefinitions>

                    <!--  =================================================  -->
                    <!--  ================= INFORMACION ===================  -->
                    <!--  =================================================  -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">

                        <Border
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="16">

                            <StackPanel Spacing="14">

                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="Información general" />

                                <Border
                                    Height="1"
                                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    Opacity="0.4" />


                                <StackPanel Spacing="4">

                                    <TextBlock Opacity="0.7" Text="Fecha Registro" />

                                    <TextBlock FontWeight="SemiBold" Text="{Binding FechaRegistro, Converter={StaticResource DateFormatConverter}}" />

                                </StackPanel>

                                <TextBox
                                    Header="Nombre"
                                    PlaceholderText="Nombre del producto"
                                    Text="{Binding Nombre, Mode=TwoWay}" />

                                <TextBox
                                    MinHeight="100"
                                    VerticalContentAlignment="Top"
                                    AcceptsReturn="True"
                                    Header="Descripción"
                                    PlaceholderText="Descripción del producto"
                                    Text="{Binding Descripcion, Mode=TwoWay}"
                                    TextWrapping="Wrap" />

                                <TextBox
                                    Header="Código de barras"
                                    PlaceholderText="Código de barras"
                                    Text="{Binding CodigoBarra, Mode=TwoWay}" />

                                <StackPanel Spacing="8">

                                    <ComboBox
                                        DisplayMemberPath="Nombre"
                                        Header="Categoría"
                                        ItemsSource="{Binding Categorias}"
                                        PlaceholderText="Seleccione una categoría"
                                        SelectedItem="{Binding CategoriaSeleccionada, Mode=TwoWay}" />

                                    <Button
                                        Width="42"
                                        Height="42"
                                        HorizontalAlignment="Left"
                                        Command="{Binding NuevaCategoriaCommand}">

                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE710;" />

                                    </Button>

                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <!--  =================================================  -->
                    <!--  ================= CONFIG ========================  -->
                    <!--  =================================================  -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Column="1">

                        <Border
                            Grid.Column="1"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="16">

                            <StackPanel Spacing="14">

                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="Configuración" />

                                <Border
                                    Height="1"
                                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    Opacity="0.4" />

                                <TextBox Header="Precio compra" Text="{Binding PrecioCompra, Mode=TwoWay, Converter={StaticResource DecimalToStringConverter}, UpdateSourceTrigger=PropertyChanged}" />

                                <NumberBox
                                    Header="Existencia"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{Binding Existencia, Mode=TwoWay}" />

                                <TextBox
                                    Header="Ganancia %"
                                    IsEnabled="{Binding PrecioAutomatico, Converter={StaticResource InverseBooleanConverter}}"
                                    Text="{Binding PorcentajeGanancia, Mode=TwoWay, Converter={StaticResource DecimalToStringConverter}, UpdateSourceTrigger=PropertyChanged}" />

                                <Border
                                    Padding="10"
                                    Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                                    CornerRadius="12">

                                    <StackPanel Spacing="10">
                                        <ToggleSwitch Header="Precio automático" IsOn="{Binding PrecioAutomatico, Mode=TwoWay}" />

                                        <ToggleSwitch Header="Aplicar ITBIS" IsOn="{Binding AplicaItbis, Mode=TwoWay}" />

                                        <ToggleSwitch Header="Producto activo" IsOn="{Binding Estado, Mode=TwoWay}" />



                                    </StackPanel>

                                </Border>

                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <!--  =================================================  -->
                    <!--  ================= MINORISTA =====================  -->
                    <!--  =================================================  -->

                    <Border
                        Grid.Column="2"
                        Padding="18"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="16">

                        <StackPanel Spacing="16">

                            <StackPanel Orientation="Horizontal" Spacing="10">

                                <FontIcon Glyph="&#xE719;" />

                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="Precio Minorista" />

                            </StackPanel>

                            <Border
                                Height="1"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                Opacity="0.4" />

                            <!--  PRECIO  -->
                            <Border
                                Padding="14"
                                Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                                CornerRadius="14">

                                <StackPanel Spacing="6">

                                    <TextBlock Opacity="0.7" Text="Precio final" />

                                    <TextBlock
                                        FontSize="32"
                                        FontWeight="Bold"
                                        Text="{Binding PrecioFinalMinorista, Converter={StaticResource NumeroConverterHelper}}" />

                                </StackPanel>

                            </Border>

                            <!--  DETALLES  -->
                            <Grid RowSpacing="12">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Opacity="0.7"
                                    Text="Precio base" />

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    FontWeight="SemiBold"
                                    Text="{Binding PrecioBase, Converter={StaticResource NumeroConverterHelper}}" />

                                <TextBlock
                                    Grid.Row="1"
                                    Opacity="0.7"
                                    Text="ITBIS" />

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    FontWeight="SemiBold"
                                    Text="{Binding Itbis, Converter={StaticResource NumeroConverterHelper}}" />

                                <TextBlock
                                    Grid.Row="2"
                                    Opacity="0.7"
                                    Text="Ganancia" />

                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    FontWeight="SemiBold"
                                    Text="{Binding Ganancia, Converter={StaticResource NumeroConverterHelper}}" />

                                <TextBlock
                                    Grid.Row="3"
                                    Opacity="0.7"
                                    Text="Porcentaje" />

                                <TextBlock
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    FontWeight="SemiBold">

                                    <Run Text="{Binding PorcentajeGanancia}" />
                                    <Run Text="%" />

                                </TextBlock>

                            </Grid>

                        </StackPanel>

                    </Border>

                    <!--  =================================================  -->
                    <!--  ================= MAYORISTA =====================  -->
                    <!--  =================================================  -->

                    <Border
                        Grid.Column="3"
                        Padding="18"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="16">

                        <StackPanel Spacing="16">

                            <StackPanel Orientation="Horizontal" Spacing="10">

                                <FontIcon Glyph="&#xE719;" />

                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="Precio Final" />

                            </StackPanel>

                            <Border
                                Height="1"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                Opacity="0.4" />

                            <!--  PRECIO  -->
                            <Border
                                Padding="14"
                                Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                                CornerRadius="14">

                                <StackPanel Spacing="6">

                                    <TextBlock Opacity="0.7" Text="Precio mayorista" />

                                    <TextBlock
                                        FontSize="32"
                                        FontWeight="Bold"
                                        Text="{Binding PrecioFinalMayorista, Converter={StaticResource NumeroConverterHelper}}" />

                                </StackPanel>

                            </Border>

                            <!--  DETALLES  -->
                            <Grid RowSpacing="12">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Opacity="0.7"
                                    Text="Precio Base" />

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    FontWeight="SemiBold"
                                    Text="{Binding PrecioBaseMayorista, Converter={StaticResource NumeroConverterHelper}}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Opacity="0.7"
                                    Text="ITBIS" />

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    FontWeight="SemiBold"
                                    Text="{Binding Itbis, Converter={StaticResource NumeroConverterHelper}}" />
                                <TextBlock
                                    Grid.Row="2"
                                    Opacity="0.7"
                                    Text="Ganancia" />

                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    FontWeight="SemiBold"
                                    Text="{Binding GananciaMayorista, Converter={StaticResource NumeroConverterHelper}}" />

                                <TextBlock
                                    Grid.Row="3"
                                    Opacity="0.7"
                                    Text="Porcentaje" />

                                <TextBlock
                                    Grid.Row="4"
                                    Grid.Column="1"
                                    FontWeight="SemiBold">

                                    <Run Text="{Binding PorcentajeMayoristaCalculado}" />
                                    <Run Text="%" />

                                </TextBlock>

                            </Grid>

                        </StackPanel>

                    </Border>

                </Grid>

                <!--  ================= ACTIONS =================  -->
                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="12">

                    <Button
                        Command="{Binding CancelarCommand}"
                        Content="Cancelar"
                        Style="{ThemeResource ButtonRevealStyle}" />

                    <Button MinWidth="140" Command="{Binding GuardarCommand}">

                        <StackPanel Orientation="Horizontal" Spacing="10">

                            <FontIcon Glyph="&#xF78C;" />

                            <TextBlock Text="Guardar" />

                            <ProgressRing
                                Width="18"
                                Height="18"
                                IsActive="{Binding IsLoading}"
                                Visibility="{Binding IsLoading}" />

                        </StackPanel>

                    </Button>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</UserControl>