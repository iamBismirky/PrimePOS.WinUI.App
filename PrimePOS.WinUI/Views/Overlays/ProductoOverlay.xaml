<UserControl
    x:Class="PrimePOS.WinUI.Views.Overlays.ProductoOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <Border
            Width="900"
            Padding="20"
            CornerRadius="16"
            Background="{ThemeResource SolidBackgroundFillColorBase}">

            <Grid RowSpacing="16">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ================= HEADER ================= -->
                <StackPanel Grid.Row="0" Spacing="4">

                    <TextBlock Text="Producto"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="Gestión de información, precios e impuestos"
                               Opacity="0.6"/>

                    <Border Height="1"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                            Opacity="0.4"/>
                </StackPanel>

                <!-- ================= BODY ================= -->
                <Grid Grid.Row="1" ColumnSpacing="16">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ===== DATOS ===== -->
                    <Border Padding="14"
                            CornerRadius="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                        <StackPanel Spacing="10">

                            <TextBlock Text="Información"
                                       FontWeight="SemiBold"
                                       Opacity="0.7"/>

                            <TextBox Header="Nombre"
                                     Text="{Binding Nombre, Mode=TwoWay}"/>

                            <TextBox Header="Descripción"
                                     Text="{Binding Descripcion, Mode=TwoWay}"/>

                            <TextBox Header="Código de barras"
                                     Text="{Binding CodigoBarra, Mode=TwoWay}"/>

                            <ComboBox Header="Categoría"
                                      ItemsSource="{Binding Categorias}"
                                      DisplayMemberPath="Nombre"
                                      SelectedItem="{Binding CategoriaSeleccionada}"/>

                        </StackPanel>
                    </Border>

                    <!-- ===== CONFIG ===== -->
                    <Border Grid.Column="1"
                            Padding="14"
                            CornerRadius="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                        <StackPanel Spacing="10">

                            <TextBlock Text="Configuración"
                                       FontWeight="SemiBold"
                                       Opacity="0.7"/>

                            <TextBox Header="Precio compra"
                                     Text="{Binding PrecioCompra, Mode=TwoWay,
                                     Converter={StaticResource DecimalToStringConverter},
                                     UpdateSourceTrigger=PropertyChanged}"/>

                            <NumberBox Header="Existencia"
                                       Value="{Binding Existencia, Mode=TwoWay}"/>

                            <ToggleSwitch Header="Activo"
                                          IsOn="{Binding Estado, Mode=TwoWay}"/>

                            <ToggleSwitch Header="Precio automático"
                                          IsOn="{Binding PrecioAutomatico, Mode=TwoWay}"/>

                            <TextBox Header="Ganancia %"
                                     IsEnabled="{Binding PrecioAutomatico, Converter={StaticResource InverseBooleanConverter}}"
                                     Text="{Binding PorcentajeGanancia, Mode=TwoWay,
                                     UpdateSourceTrigger=PropertyChanged}"/>

                        </StackPanel>
                    </Border>

                    <!-- ===== PREVIEW ===== -->
                    <Border Grid.Column="2"
                            Padding="16"
                            CornerRadius="12"
                            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}">

                        <StackPanel Spacing="12">

                            <TextBlock Text="Resumen de precios"
                                       FontWeight="SemiBold"
                                       Opacity="0.7"/>

                            <Border Padding="12"
                                    CornerRadius="10"
                                    Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}">

                                <StackPanel Spacing="8">

                                    <TextBlock Text="Precio base"/>
                                    <TextBlock Text="{Binding PrecioBase,
                                        Converter={StaticResource NumeroConverterHelper}}"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="ITBIS"/>
                                    <TextBlock Text="{Binding Itbis,
                                        Converter={StaticResource NumeroConverterHelper}}"/>

                                    <Border Height="1"
                                            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            Opacity="0.4"/>

                                    <TextBlock Text="Precio final"
                                               FontSize="14"
                                               Opacity="0.7"/>

                                    <TextBlock Text="{Binding PrecioFinal,
                                        Converter={StaticResource NumeroConverterHelper}}"
                                               FontSize="26"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="Ganancia"
                                               Opacity="0.7"/>

                                    <TextBlock Text="{Binding Ganancia,
                                        Converter={StaticResource NumeroConverterHelper}}"
                                               FontWeight="SemiBold"/>

                                </StackPanel>

                            </Border>

                        </StackPanel>

                    </Border>

                </Grid>

                <!-- ================= ACTIONS ================= -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10">

                    <Button Content="Cancelar"
                            Command="{Binding CancelarCommand}"
                            Style="{ThemeResource ButtonRevealStyle}"/>

                    <Button>
                        <StackPanel Orientation="Horizontal" Spacing="8">

                            <FontIcon Glyph="&#xF78C;"/>

                            <TextBlock Text="Guardar"/>

                            <ProgressRing Width="18"
                                          Height="18"
                                          IsActive="{Binding IsLoading}"
                                          Visibility="{Binding IsLoading}"/>

                        </StackPanel>

                    </Button>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</UserControl>