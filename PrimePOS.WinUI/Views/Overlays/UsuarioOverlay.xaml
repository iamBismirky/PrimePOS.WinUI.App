<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PrimePOS.WinUI.Views.Overlays.UsuarioOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI.Views.Overlays"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>

        <Border Width="400"
             Padding="20"
             Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
             CornerRadius="12"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">

            <StackPanel Spacing="10">

                <TextBlock Text="Usuario"
                        FontSize="18"
                        FontWeight="SemiBold"/>

                <Line X1="0" X2="1" Stretch="Fill" Stroke="Gray" StrokeThickness="1"/>

                <StackPanel Orientation="Horizontal" Spacing="50" HorizontalAlignment="Stretch">
                    <TextBlock>
                     <Run Text="Codigo"/>
                     <Run Text="{Binding Codigo}"/>
                    </TextBlock>
                    <TextBlock>
                     <Run Text="Fecha Registro"/>
                     <Run Text="{Binding FechaRegistro}"/>
                    </TextBlock>
                </StackPanel>


                <Line X1="0" X2="1" Stretch="Fill" Stroke="Gray" StrokeThickness="1"/>
                <TextBox Header="Nombre" 
                      Text="{Binding Nombre, Mode=TwoWay}"/>
                <TextBox Header="Apellidos" 
                      Text="{Binding Apellidos, Mode=TwoWay}"/>
                <TextBox Header="Username" 
                      Text="{Binding Username, Mode=TwoWay}"/>
                <PasswordBox Header="Password" 
                          Password="{Binding Password, Mode=TwoWay}"
                          PasswordChar="#"/>
                <ComboBox Header="Rol" 
                       DisplayMemberPath="Nombre"
                       PlaceholderText="Seleccione un rol"
                       SelectedItem="{Binding RolSeleccionado, Mode=TwoWay}" 
                       ItemsSource="{Binding Roles}"/>
                <ToggleSwitch Header="Estado" 
                           IsOn="{Binding Estado, Mode=TwoWay}"/>

                <Line X1="0" X2="1" Stretch="Fill" Stroke="Gray" StrokeThickness="1"/>

                <StackPanel Orientation="Horizontal"
                         HorizontalAlignment="Right"
                         Spacing="10">

                    <Button Command="{Binding CancelarCommand}"
                         Background="Red">
                        <TextBlock Text="Cancelar"/>
                    </Button>

                    <Button Command="{Binding GuardarCommand}"
                         Background="#FF2D89EF"
                         Foreground="White">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xF78C;" FontFamily="Segoe Fluent Icons"/>
                            <TextBlock x:Name="txtGuardar" Text="Guardar"/>
                            <ProgressRing Width="20"
                                       Height="20"
                                       IsActive="{Binding IsLoading}"
                                       Visibility="{Binding IsLoading}"/>
                        </StackPanel>
                    </Button>



                </StackPanel>

            </StackPanel>

        </Border>

    </Grid>
</UserControl>
