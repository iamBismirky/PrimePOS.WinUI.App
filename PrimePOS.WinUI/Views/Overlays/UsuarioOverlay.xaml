<UserControl
    x:Class="PrimePOS.WinUI.Views.Overlays.UsuarioOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <Border
            Width="520"
            Padding="25"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
            CornerRadius="16">

            <Grid RowSpacing="15">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  ================= HEADER =================  -->
                <StackPanel Spacing="4">

                    <TextBlock
                        FontSize="22"
                        FontWeight="Bold"
                        Text="Usuario del sistema" />

                    <TextBlock Opacity="0.6" Text="Gestión de cuentas y acceso" />

                </StackPanel>

                <!--  ================= INFO ROW =================  -->
                <Border
                    Grid.Row="1"
                    Padding="10"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="10">

                    <Grid ColumnSpacing="20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Opacity="0.6" Text="Código" />
                            <TextBlock Text="{Binding Codigo}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Opacity="0.6" Text="Fecha registro" />
                            <TextBlock Text="{Binding FechaRegistro}" />
                        </StackPanel>

                    </Grid>

                </Border>

                <!--  ================= FORM =================  -->
                <StackPanel Grid.Row="2" Spacing="12">

                    <TextBox Header="Nombre" Text="{Binding Nombre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox Header="Apellidos" Text="{Binding Apellidos, Mode=TwoWay}" />

                    <TextBox Header="Usuario" Text="{Binding Username, Mode=TwoWay}" />

                    <PasswordBox
                        Header="Contraseña"
                        Password="{Binding Password, Mode=TwoWay}"
                        PasswordChar="●" />

                    <ComboBox
                        DisplayMemberPath="Nombre"
                        Header="Rol"
                        ItemsSource="{Binding Roles}"
                        PlaceholderText="Seleccionar rol"
                        SelectedItem="{Binding RolSeleccionado, Mode=TwoWay}" />

                    <ToggleSwitch Header="Usuario activo" IsOn="{Binding Estado, Mode=TwoWay}" />

                </StackPanel>

                <!--  ================= ACTIONS =================  -->
                <Border
                    Grid.Row="4"
                    Padding="5"
                    Background="Transparent">

                    <Grid ColumnSpacing="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  CANCELAR  -->
                        <Button
                            Grid.Column="0"
                            Height="42"
                            Background="#C42B1C"
                            Command="{Binding CancelarCommand}"
                            Foreground="White">

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE711;" />
                                <TextBlock Text="Cancelar" />
                            </StackPanel>

                        </Button>

                        <!--  GUARDAR  -->
                        <Grid Grid.Column="1">

                            <Button
                                Height="42"
                                HorizontalAlignment="Right"
                                Background="#2D89EF"
                                Command="{Binding GuardarCommand}"
                                Foreground="White">

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74E;" />
                                    <TextBlock Text="Guardar" />
                                </StackPanel>

                            </Button>

                            <ProgressRing
                                Width="22"
                                Height="22"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsActive="{Binding IsLoading}" />

                        </Grid>

                    </Grid>

                </Border>

            </Grid>

        </Border>

    </Grid>

</UserControl>