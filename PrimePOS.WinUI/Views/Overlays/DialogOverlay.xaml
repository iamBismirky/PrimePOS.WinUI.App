<UserControl
    x:Class="PrimePOS.WinUI.Views.Overlays.DialogOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>


        <!--  DIALOG  -->
        <Border
            Width="420"
            Padding="20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{ThemeResource SolidBackgroundFillColorBase}"
            CornerRadius="16">

            <StackPanel Spacing="16">

                <!--  ICON + TITLE  -->
                <StackPanel Orientation="Horizontal" Spacing="10">

                    <Grid Width="36" Height="36">
                        <Ellipse Fill="#FFE81123" Opacity="0.15" />
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="18"
                            Foreground="#FFE81123"
                            Glyph="&#xE7BA;" />
                    </Grid>

                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="{Binding Title}" />
                </StackPanel>

                <!--  MESSAGE  -->
                <TextBlock
                    FontSize="14"
                    Opacity="0.75"
                    Text="{Binding Message}"
                    TextWrapping="Wrap" />

                <!--  DIVIDER  -->
                <Border
                    Height="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                    Opacity="0.4" />

                <!--  ACTIONS  -->
                <StackPanel
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="10">

                    <Button
                        Command="{Binding CancelarCommand}"
                        Content="Cancelar"
                        Style="{ThemeResource ButtonRevealStyle}" />

                    <Button Command="{Binding ConfirmarCommand}" Content="Eliminar">

                        <Button.Background>
                            <SolidColorBrush Color="#E81123" />
                        </Button.Background>

                        <Button.Foreground>
                            <SolidColorBrush Color="White" />
                        </Button.Foreground>

                    </Button>

                </StackPanel>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>