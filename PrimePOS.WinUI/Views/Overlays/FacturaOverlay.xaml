<UserControl
    x:Class="PrimePOS.WinUI.Views.Overlays.FacturaOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#80000000">

        <Border Width="900"
            Height="650"
            Background="{ThemeResource SolidBackgroundFillColorBase}"
            CornerRadius="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid Grid.Row="0"
                          Padding="10">

                        <TextBlock Text="Vista previa PDF"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>

                        <Button Content="X"
                                HorizontalAlignment="Right"
                                Click="Cerrar_Click"/>
                    </Grid>
                </Grid>
                <WebView2 x:Name="PdfViewer"
                          Grid.Row="1"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>