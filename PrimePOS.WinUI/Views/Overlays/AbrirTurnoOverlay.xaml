<UserControl
    x:Class="PrimePOS.WinUI.Views.Overlays.AbrirTurnoOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <Border Width="400"
                Padding="20"
                Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Spacing="10">

                <TextBlock Text="Abrir Turno"
                           FontSize="22"
                           FontWeight="Bold"/>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Caja" FontSize="18" FontWeight="SemiBold"/>
                    <ComboBox 
                            ItemsSource="{Binding Cajas}"
                            SelectedItem="{Binding CajaSeleccionada}"
                            DisplayMemberPath="Nombre"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Spacing="10">
                    <TextBlock Text="{Binding TurnoTexto}" FontSize="18" FontWeight="SemiBold"/>

                    <NumberBox Header="Monto Inicial"
                               Value="{Binding MontoInicial, Mode=TwoWay, Converter={StaticResource DecimalToDouble}}"
                               NumberFormatter="{StaticResource DecimalFormatter}"/>
                </StackPanel>
                

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Cancelar"
                            Command="{Binding CancelarCommand}"
                            Style="{StaticResource SubtleButtonStyle}"/>
                    <Button Content="Abrir"
                            Command="{Binding AbrirCommand}"
                            Style="{StaticResource AccentButtonStyle}"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>