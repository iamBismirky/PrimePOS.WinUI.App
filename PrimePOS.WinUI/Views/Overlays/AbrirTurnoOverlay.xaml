<UserControl
    x:Class="PrimePOS.WinUI.Views.Overlays.AbrirTurnoOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <Border
            Width="550"
            Padding="25"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{ThemeResource SolidBackgroundFillColorBase}"
            CornerRadius="18">

            <Grid RowSpacing="20">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  ================= HEADER =================  -->
                <StackPanel Grid.Row="0" Spacing="4">

                    <TextBlock
                        FontSize="30"
                        FontWeight="Bold"
                        Text="Abrir Turno" />

                    <TextBlock Opacity="0.6" Text="Configura la caja y el monto inicial" />

                </StackPanel>

                <!--  ================= CAJA =================  -->
                <Border
                    Grid.Row="1"
                    Padding="15"
                    Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                    CornerRadius="14">

                    <StackPanel Spacing="10">

                        <TextBlock
                            FontWeight="SemiBold"
                            Opacity="0.7"
                            Text="Caja" />

                        <ComboBox
                            DisplayMemberPath="Nombre"
                            ItemsSource="{Binding Cajas}"
                            SelectedItem="{Binding CajaSeleccionada}" />

                    </StackPanel>

                </Border>

                <!--  ================= TURNO INFO =================  -->
                <Border
                    Grid.Row="2"
                    Padding="15"
                    Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                    CornerRadius="14">

                    <StackPanel Spacing="10">

                        <TextBlock
                            FontWeight="SemiBold"
                            Opacity="0.7"
                            Text="Información del turno" />

                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="{Binding TurnoTexto}" />

                    </StackPanel>

                </Border>

                <!--  ================= MONTO =================  -->
                <Border
                    Grid.Row="3"
                    Padding="15"
                    Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                    CornerRadius="14">

                    <StackPanel Spacing="10">

                        <TextBlock
                            FontWeight="SemiBold"
                            Opacity="0.7"
                            Text="Monto inicial" />

                        <NumberBox NumberFormatter="{StaticResource DecimalFormatter}" Value="{Binding MontoInicial, Mode=TwoWay, Converter={StaticResource DecimalToDouble}}" />

                    </StackPanel>

                </Border>

                <!--  ================= BOTONES =================  -->
                <StackPanel
                    Grid.Row="5"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="12">

                    <Button
                        Padding="25,10"
                        Command="{Binding CancelarCommand}"
                        Content="Cancelar"
                        Style="{StaticResource SubtleButtonStyle}" />

                    <Button
                        Padding="25,10"
                        Command="{Binding AbrirCommand}"
                        Content="Abrir Turno"
                        Style="{StaticResource AccentButtonStyle}" />

                </StackPanel>

            </Grid>

        </Border>

    </Grid>
</UserControl>