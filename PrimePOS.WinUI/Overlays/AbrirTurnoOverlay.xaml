<UserControl
    x:Class="PrimePOS.WinUI.Overlays.AbrirTurnoOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI.Pages"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    Loaded="Page_loaded">

    <!-- Canvas como contenedor principal -->
    <Grid Background="#80000000">

        
        <!-- Border central flotante -->
        <Border x:Name="DialogBorder"
                Width="350"
                Height="400"
                Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                CornerRadius="20"
                Padding="20"
                Canvas.Left="350" Canvas.Top="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Canvas.ZIndex="99">

            <StackPanel Spacing="15">

                <TextBlock Text="Abrir Turno"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <Line X1="0" X2="1" Stretch="Fill" Stroke="Gray" StrokeThickness="1"/>

                <ComboBox x:Name="cmbCajas"
                          PlaceholderText="Selecciona Caja"
                          DisplayMemberPath="Nombre"
                          SelectedValuePath="Id"
                          Header="Caja"/>

                <NumberBox x:Name="nbMontoInicial"
                           PlaceholderText="Monto inicial"
                           Value="0"
                           Header="Monto Inicial"/>

                <ComboBox x:Name="cmbTurnos"
                          PlaceholderText="Selecciona Turno"
                          Header="Turno"/>
                
                <TextBlock x:Name="txtTextoTurnoPreview"/>


                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                    <Button Content="Cancelar" Width="100" Click="BtnCancelar_Click"/>
                    <Button Content="Abrir" Width="100" Click="BtnAbrir_Click"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>