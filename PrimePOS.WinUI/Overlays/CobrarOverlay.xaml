<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PrimePOS.WinUI.Overlays.CobrarOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Background="#80000000">
        <Border Width="400"
            Padding="20"
            Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
            CornerRadius="12"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <StackPanel Spacing="12">

                <TextBlock Text="Cobrar"
                       FontSize="22"
                       FontWeight="Bold"/>
                
                <Line X1="0" X2="1" Stretch="Fill" Stroke="Gray" StrokeThickness="1"/>

                <TextBlock Text="{Binding Total}"
                       FontSize="18"
                       Foreground="Green"/>
                
                <StackPanel>
                    <TextBox Text="{Binding EfectivoTexto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Header="Efectivo"
                             x:Name="txtEfectivo"
                             GotFocus="Confirmar_Click"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Cambio"/>
                    <TextBlock Text="{Binding Cambio}"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Falta"/>
                    <TextBlock Text="{Binding Falta}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{Binding FaltaColor}"/>


                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar"
                            Click="Cancelar_Click"
                            Background="PaleVioletRed"
                            Foreground="White"/>
                    <Button Content="Confirmar Pago"
                            Click="Confirmar_Click"
                            Background="Green"
                            Foreground="White"/>
                    
                </StackPanel>
                
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
