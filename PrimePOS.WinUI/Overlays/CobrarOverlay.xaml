<UserControl
    x:Class="PrimePOS.WinUI.Overlays.CobrarOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <Grid>

        <Border Width="350"
                Padding="20"
                Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Spacing="10">

                <TextBlock Text="Cobrar"
                           FontSize="22"
                           FontWeight="Bold" />
                <StackPanel Orientation="Vertical" Spacing="10">
                    <TextBlock Text="Total" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Total, Converter={StaticResource NumeroConverterHelper}}" 
                               FontSize="18" 
                               FontWeight="SemiBold"/>
                    

                </StackPanel>

                <StackPanel Orientation="Vertical" Spacing="10">
                    <TextBlock Text="Efectivo" FontSize="18" FontWeight="Bold"/>
                    <TextBox x:Name="txtEfectivo"
                            Text="{Binding EfectivoTexto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            LostFocus="txtEfectivo_LostFocus"
                             FontSize="18"/>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Faltante" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Cambio, Converter={StaticResource NumeroConverterHelper}}"
                               FontSize="18"/>
                </StackPanel>

                

                <StackPanel Orientation="Horizontal" Spacing="10">

                    <Button Content="Cancelar"
                            Command="{Binding CancelarCommand}" />
                    <Grid>
                        <Button Content="Confirmar"
                                Command="{Binding ConfirmarCommand}" />
                        <ProgressRing
                            IsActive="{Binding IsLoading}"
                            Width="30"
                            Height="30"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Grid>
                    
                    


                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>