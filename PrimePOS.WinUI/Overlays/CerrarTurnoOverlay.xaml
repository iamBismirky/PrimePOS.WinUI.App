<UserControl
    x:Class="PrimePOS.WinUI.Overlays.CerrarTurnoOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <Border Width="400"
                Padding="20"
                Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Spacing="10">

                <TextBlock Text="Cerrar Turno"
                           FontSize="22"
                           FontWeight="Bold"/>

                <TextBlock Text="{Binding MontoInicial}"/>
                <TextBlock Text="{Binding TotalEfectivo}"/>
                <TextBlock Text="{Binding TotalTarjeta}"/>
                <TextBlock Text="{Binding TotalTransferencia}"/>

                <NumberBox Header="Efectivo contado"
                           Value="{Binding EfectivoContado, Mode=TwoWay}" />

                <TextBlock Text="{Binding Diferencia}"
                           Foreground="Red"/>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Cancelar"
                            Command="{Binding CancelarCommand}" />
                    <Button Content="Cerrar Turno"
                            Command="{Binding CerrarCommand}" />
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>