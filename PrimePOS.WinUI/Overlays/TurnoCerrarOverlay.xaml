<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PrimePOS.WinUI.Overlays.TurnoCerrarOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrimePOS.WinUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Background="#80000000">
        <!-- Fondo oscuro tipo overlay -->

        <Border Width="500"
            Background="{ThemeResource CardStrokeColorDefaultSolidBrush}"
            CornerRadius="12"
            Padding="20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <StackPanel Spacing="12">

                <!-- Título -->
                <TextBlock Text="Cierre de Turno"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

                <!-- Separador -->
                <Line X1="0" X2="1" Stretch="Fill" Stroke="Gray" StrokeThickness="1"/>

                <!-- Info del turno -->
                <StackPanel>
                    <TextBlock Text="Turno:" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding NumeroTurno}" FontSize="16"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Monto Inicial::" Width="200"/>
                    <TextBlock Text="{Binding MontoInicial}" FontWeight="Bold"/>
                </StackPanel>
                <!-- Gastos -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Total Efectivo:" Width="200"/>
                    <TextBlock Text="{Binding TotalEfectivo}" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Total Tarjeta:" Width="200"/>
                    <TextBlock Text="{Binding TotalTarjeta}" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Total Transferencia:" Width="200"/>
                    <TextBlock Text ="{Binding TotalTransferencia}" FontWeight="Bold"/>
                </StackPanel>
                <!-- Ventas -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <TextBlock Text="Total General:" Width="200"/>
                    <TextBlock Text ="{Binding TotalGeneral}" FontWeight="Bold"/>
                </StackPanel>
                <!-- Efectivo esperado -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Efectivo Esperado:" Width="200"/>
                    <TextBlock Text ="{Binding EfectivoEsperado}" FontWeight="Bold"/>
                </StackPanel>

                <!-- Input efectivo contado -->
                <StackPanel>
                    <TextBlock Text="Efectivo Contado"/>
                    <TextBox Text ="{Binding EfectivoContado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               PlaceholderText="Ingrese monto"
                               />
                </StackPanel>

                <!-- Diferencia -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Diferencia:" Width="200"/>
                    <TextBlock Text ="{Binding Diferencia}"
                           Foreground="{Binding DiferenciaColor}"
                           FontWeight="Bold"/>
                </StackPanel>

                <!-- Botones -->
                <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10"
                        Margin="0,10,0,0">

                    <Button Content="Cancelar"
                        Background="Gray"
                        Foreground="White"
                        Click="BtnCancelar_Click"/>

                    <Button Content="Cerrar Turno"
                        Background="#0078D4"
                        Foreground="White"
                        Click="BtnCerrarTurno_Click"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
